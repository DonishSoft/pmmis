<script>
    // Toggle amendment form sections based on type
    document.getElementById('amendmentType').addEventListener('change', function() {
        var type = parseInt(this.value);
        var amountFields = document.getElementById('amountFields');
        var dateFields = document.getElementById('dateFields');
        var scopeFields = document.getElementById('scopeFields');
        
        amountFields.style.display = (type === 0 || type === 2) ? 'block' : 'none';
        dateFields.style.display = (type === 1 || type === 2) ? 'block' : 'none';
        scopeFields.style.display = (type === 2) ? 'block' : 'none';
    });
    
    // Convert TJS to USD
    function convertToUsd() {
        var tjs = parseFloat(document.getElementById('amtTjs').value) || 0;
        var rate = parseFloat(document.getElementById('amtRate').value) || 0;
        var usdField = document.getElementById('amtUsd');
        if (tjs > 0 && rate > 0) {
            usdField.value = (tjs / rate).toFixed(2);
        } else {
            usdField.value = '';
        }
    }
    
    // Add additional document row
    var amendDocIdx = 0;
    function addAmendmentDocRow() {
        var container = document.getElementById('amendmentDocsContainer');
        var row = document.createElement('div');
        row.className = 'row g-2 mb-2 align-items-end';
        row.innerHTML = `
            <div class="col-5">
                <input type="file" name="AdditionalFiles" class="form-control form-control-sm" />
            </div>
            <div class="col-5">
                <input type="text" name="AdditionalNames" class="form-control form-control-sm" placeholder="Название документа" />
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.row').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
    }
</script>
}

<script>
    // ===== Work Items (Объём работ) =====
    const contractId = @Model.Id;
    const canEditItems = @(canEdit ? "true" : "false");
    let workItems = [];
    let workItemsDirty = false;

    document.addEventListener('DOMContentLoaded', loadWorkItems);
    
    if (canEditItems) {
        document.getElementById('addWorkItemBtn')?.addEventListener('click', addWorkItem);
        document.getElementById('saveWorkItemsBtn')?.addEventListener('click', saveWorkItems);
    }

    async function loadWorkItems() {
        const resp = await fetch(`/Contracts/GetWorkItems?contractId=${contractId}`);
        workItems = await resp.json();
        renderWorkItems();
    }

    // Search filter
    document.getElementById('workItemsSearch')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        const rows = document.querySelectorAll('#workItemsBody tr');
        rows.forEach(row => {
            const name = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
            row.style.display = name.includes(q) ? '' : 'none';
        });
    });

    function renderWorkItems() {
        const tbody = document.getElementById('workItemsBody');
        const empty = document.getElementById('workItemsEmpty');
        const count = document.getElementById('workItemsCount');
        
        count.textContent = workItems.length + ' позиц' + (workItems.length === 1 ? 'ия' : workItems.length < 5 ? 'ии' : 'ий');
        
        if (workItems.length === 0) {
            tbody.innerHTML = '';
            empty.classList.remove('d-none');
            return;
        }
        empty.classList.add('d-none');
        
        let currentCat = '';
        tbody.innerHTML = workItems.map((item, idx) => {
            const pct = item.targetQuantity > 0 ? Math.min(100, (item.achievedQuantity / item.targetQuantity) * 100) : 0;
            const barClass = pct >= 80 ? 'bg-success' : pct >= 50 ? 'bg-info' : pct >= 25 ? 'bg-warning' : 'bg-danger';
            const isNew = !item.id || item.id === 0;
            
            let catHeader = '';
            if (item.category && item.category !== currentCat) {
                currentCat = item.category;
                catHeader = `<tr class="table-secondary"><td colspan="${canEditItems ? 7 : 6}"><strong><i class="bi bi-folder2 me-1"></i>${escHtml(currentCat)}</strong></td></tr>`;
            }
            
            if (isNew || workItemsDirty) {
                // Editable row
                return catHeader + `<tr>
                    <td class="text-center text-muted">${idx + 1}</td>
                    <td><input type="text" class="form-control form-control-sm" value="${escHtml(item.name)}" 
                         onchange="updateItem(${idx}, 'name', this.value)" placeholder="Наименование работы..." /></td>
                    <td><select class="form-select form-select-sm" onchange="updateItem(${idx}, 'unit', this.value)">
                        ${unitOptions(item.unit)}
                    </select></td>
                    <td><input type="number" class="form-control form-control-sm text-end" value="${item.targetQuantity}" 
                         min="0" step="0.01" onchange="updateItem(${idx}, 'targetQuantity', parseFloat(this.value)||0)" /></td>
                    <td class="text-end">${item.achievedQuantity}</td>
                    <td><div class="progress" style="height:18px">
                        <div class="progress-bar ${barClass}" style="width:${pct.toFixed(0)}%">${pct.toFixed(1)}%</div>
                    </div></td>
                    ${canEditItems ? `<td><button class="btn btn-sm btn-outline-danger" onclick="removeItem(${idx})" title="Удалить"><i class="bi bi-x-lg"></i></button></td>` : ''}
                </tr>`;
            }
            // Readonly row
            return catHeader + `<tr>
                <td class="text-center text-muted">${idx + 1}</td>
                <td><strong>${escHtml(item.name)}</strong></td>
                <td>${escHtml(item.unit)}</td>
                <td class="text-end">${item.targetQuantity}</td>
                <td class="text-end">${item.achievedQuantity}</td>
                <td><div class="progress" style="height:18px">
                    <div class="progress-bar ${barClass}" style="width:${pct.toFixed(0)}%">${pct.toFixed(1)}%</div>
                </div></td>
                ${canEditItems ? `<td><button class="btn btn-sm btn-outline-danger" onclick="removeItem(${idx})" title="Удалить"><i class="bi bi-x-lg"></i></button></td>` : ''}
            </tr>`;
        }).join('');
    }

    function unitOptions(selected) {
        const units = ['куб.м', 'тонна', 'м²', 'км', 'м', 'шт', 'комплект', 'Да/Нет'];
        return units.map(u => `<option value="${u}" ${u === selected ? 'selected' : ''}>${u}</option>`).join('');
    }

    function addWorkItem() {
        workItems.push({ id: 0, name: '', unit: 'куб.м', targetQuantity: 0, achievedQuantity: 0 });
        workItemsDirty = true;
        document.getElementById('saveWorkItemsBtn')?.classList.remove('d-none');
        renderWorkItems();
    }

    function updateItem(idx, field, value) {
        workItems[idx][field] = value;
        workItemsDirty = true;
        document.getElementById('saveWorkItemsBtn')?.classList.remove('d-none');
    }

    function removeItem(idx) {
        if (!confirm('Удалить позицию "' + (workItems[idx].name || '—') + '"?')) return;
        workItems.splice(idx, 1);
        workItemsDirty = true;
        document.getElementById('saveWorkItemsBtn')?.classList.remove('d-none');
        renderWorkItems();
    }

    async function saveWorkItems() {
        const btn = document.getElementById('saveWorkItemsBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Сохранение...';
        
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value 
                    || document.querySelector('meta[name="csrf-token"]')?.content || '';
        
        const resp = await fetch(`/Contracts/SaveWorkItems?contractId=${contractId}`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(workItems.map(i => ({
                id: i.id || 0,
                name: i.name,
                unit: i.unit,
                targetQuantity: i.targetQuantity
            })))
        });
        
        if (resp.ok) {
            workItemsDirty = false;
            btn.classList.add('d-none');
            await loadWorkItems();
        } else {
            alert('Ошибка сохранения');
        }
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Сохранить';
    }

    // ===== Change History Loading =====
    (async function() {
        const resp = await fetch('/Contracts/GetHistory?id=@Model.Id');
        if (!resp.ok) return;
        const logs = await resp.json();
        const body = document.getElementById('historyBody');
        const empty = document.getElementById('historyEmpty');
        const count = document.getElementById('historyCount');

        if (logs.length === 0) { empty.classList.remove('d-none'); count.textContent = '0'; return; }
        count.textContent = logs.length;

        function renderLogItem(log) {
            const dt = new Date(log.timestamp);
            const dateStr = dt.toLocaleDateString('ru-RU', { day:'2-digit', month:'2-digit', year:'numeric' }) 
                          + ' ' + dt.toLocaleTimeString('ru-RU', { hour:'2-digit', minute:'2-digit' });
            
            let actionBadge = '';
            if (log.action === 'Создание') actionBadge = '<span class="badge bg-success">Создание</span>';
            else if (log.action === 'Удаление') actionBadge = '<span class="badge bg-danger">Удаление</span>';
            else actionBadge = '<span class="badge bg-primary">Изменение</span>';

            let changesHtml = '';
            if (log.changes) {
                try {
                    const changes = JSON.parse(log.changes);
                    changesHtml = '<div class="mt-2">';
                    changes.forEach(function(c) {
                        changesHtml += '<div class="small mb-1">'
                            + '<strong>' + escHtml(c.Field) + ':</strong> '
                            + '<span class="text-danger text-decoration-line-through">' + escHtml(c.OldValue) + '</span>'
                            + ' → '
                            + '<span class="text-success fw-semibold">' + escHtml(c.NewValue) + '</span>'
                            + '</div>';
                    });
                    changesHtml += '</div>';
                } catch(e) {}
            }
            return '<div class="list-group-item px-4 py-3">'
                + '<div class="d-flex justify-content-between align-items-start">'
                + '<div>'
                + actionBadge
                + ' <strong>' + escHtml(log.userFullName) + '</strong>'
                + (log.userPosition ? ' <span class="text-muted small">(' + escHtml(log.userPosition) + ')</span>' : '')
                + '</div>'
                + '<small class="text-muted"><i class="bi bi-clock me-1"></i>' + dateStr + '</small>'
                + '</div>'
                + changesHtml
                + '</div>';
        }

        // Show only the latest entry initially
        let html = '<div class="list-group list-group-flush">';
        html += renderLogItem(logs[0]);
        html += '</div>';
        body.innerHTML = html;

        // Store all logs for "show all" button
        window._allHistoryLogs = logs;
        if (logs.length > 1) {
            document.getElementById('historyShowAll').classList.remove('d-none');
        }
    })();

    function showAllHistory() {
        const body = document.getElementById('historyBody');
        const logs = window._allHistoryLogs;
        let html = '<div class="list-group list-group-flush">';
        logs.forEach(function(log) { html += renderLogItem(log); });
        html += '</div>';
        body.innerHTML = html;
        document.getElementById('historyShowAll').classList.add('d-none');
    }

    // Make renderLogItem accessible globally
    function renderLogItem(log) {
        const dt = new Date(log.timestamp);
        const dateStr = dt.toLocaleDateString('ru-RU', { day:'2-digit', month:'2-digit', year:'numeric' }) 
                      + ' ' + dt.toLocaleTimeString('ru-RU', { hour:'2-digit', minute:'2-digit' });
        let actionBadge = '';
        if (log.action === 'Создание') actionBadge = '<span class="badge bg-success">Создание</span>';
        else if (log.action === 'Удаление') actionBadge = '<span class="badge bg-danger">Удаление</span>';
        else actionBadge = '<span class="badge bg-primary">Изменение</span>';
        let changesHtml = '';
        if (log.changes) {
            try {
                const changes = JSON.parse(log.changes);
                changesHtml = '<div class="mt-2">';
                changes.forEach(function(c) {
                    changesHtml += '<div class="small mb-1"><strong>' + escHtml(c.Field) + ':</strong> '
                        + '<span class="text-danger text-decoration-line-through">' + escHtml(c.OldValue) + '</span> → '
                        + '<span class="text-success fw-semibold">' + escHtml(c.NewValue) + '</span></div>';
                });
                changesHtml += '</div>';
            } catch(e) {}
        }
        return '<div class="list-group-item px-4 py-3"><div class="d-flex justify-content-between align-items-start"><div>'
            + actionBadge + ' <strong>' + escHtml(log.userFullName) + '</strong>'
            + (log.userPosition ? ' <span class="text-muted small">(' + escHtml(log.userPosition) + ')</span>' : '')
            + '</div><small class="text-muted"><i class="bi bi-clock me-1"></i>' + dateStr + '</small></div>' + changesHtml + '</div>';
    }

    function escHtml(str) {
        const div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }
</script>
