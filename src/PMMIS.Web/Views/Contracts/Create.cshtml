@model PMMIS.Web.ViewModels.Contracts.ContractFormViewModel
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = "Новый контракт";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .user-ddl-item { display: flex; align-items: center; gap: 10px; padding: 4px 0; }
    .user-ddl-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 600; font-size: 12px; flex-shrink: 0; }
    .user-ddl-info { display: flex; flex-direction: column; min-width: 0; }
    .user-ddl-name { font-weight: 500; font-size: 13px; color: #212529; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-ddl-position { font-size: 11px; color: #6c757d; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-ddl-value { display: flex; align-items: center; gap: 8px; }
    .user-ddl-value .user-ddl-avatar { width: 24px; height: 24px; font-size: 10px; }
    .user-ddl-value .user-ddl-name { font-size: 13px; }
    #curatorDropdown_popup, #pmDropdown_popup { min-width: 380px !important; }
</style>

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Контракты</a></li>
            <li class="breadcrumb-item active">Новый контракт</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-10">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Contract.Id" />
                <input type="hidden" asp-for="MilestonesJson" id="milestonesJson" />
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4">
                        <h6><i class="bi bi-exclamation-triangle me-2"></i>Ошибки валидации:</h6>
                        <ul class="mb-0">
                            @foreach (var key in ViewData.ModelState.Keys)
                            {
                                @foreach (var error in ViewData.ModelState[key]!.Errors)
                                {
                                    <li><strong>@key:</strong> @error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Привязка к проекту</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Проект <span class="text-danger">*</span></label>
                                <select asp-for="Contract.ProjectId" class="form-select" id="projectSelect" required>
                                    <option value="">— Выберите —</option>
                                    @foreach (var p in Model.Projects)
                                    {
                                        <option value="@p.Id">@p.Code - @p.NameRu</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Компонент</label>
                                <select class="form-select" id="componentSelect" disabled>
                                    <option value="">— Заполняется из плана закупок —</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Подкомпонент</label>
                                <select asp-for="Contract.SubComponentId" class="form-select" id="subComponentSelect">
                                    <option value="">— Необязательно —</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-12">
                                <label class="form-label"><i class="bi bi-cart-check me-1"></i>Позиция плана закупок <span class="text-danger">*</span></label>
                                <select asp-for="Contract.ProcurementPlanId" class="form-select" id="procurementPlanSelect" required>
                                    <option value="">— Выберите позицию —</option>
                                    @foreach (var pp in Model.ProcurementPlans)
                                    {
                                        <option value="@pp.Id" data-project="@pp.ProjectId">@pp.ReferenceNo — @pp.Description (@pp.Method, @pp.EstimatedAmount.ToString("N0") USD)</option>
                                    }
                                </select>
                                <small class="text-muted">Выберите позицию плана закупок — проект, компонент и подкомпонент заполнятся автоматически</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Номер контракта <span class="text-danger">*</span></label>
                                <input type="text" asp-for="Contract.ContractNumber" class="form-control" id="contractNumber" placeholder="WSIP-AF3/W/001" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Тип контракта <span class="text-danger">*</span></label>
                                <select asp-for="Contract.Type" class="form-select" id="contractType">
                                    <option value="@((int)ContractType.Works)">🏗️ Строительные работы</option>
                                    <option value="@((int)ContractType.Consulting)">💼 Консультационные услуги</option>
                                    <option value="@((int)ContractType.Goods)">📦 Товары</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Статус контракта</label>
                                <select asp-for="Contract.Status" class="form-select" id="contractStatusSelect">
                                    <option value="@((int)ContractStatus.Ongoing)">🔄 В процессе</option>
                                    <option value="@((int)ContractStatus.DefectLiability)">🛡️ Гарантийный период</option>
                                    <option value="@((int)ContractStatus.Completed)">✅ Завершён</option>
                                    <option value="@((int)ContractStatus.Suspended)">⏸️ Приостановлен</option>
                                    <option value="@((int)ContractStatus.Terminated)">❌ Расторгнут</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Подрядчик <span class="text-danger">*</span></label>
                                <select asp-for="Contract.ContractorId" class="form-select" required>
                                    <option value="">— Выберите —</option>
                                    @foreach (var c in Model.Contractors)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- Conditional completion fields -->
                        <div class="row g-3 mt-2" id="completionFieldsRow" style="display: none">
                            <div class="col-md-4">
                                <label class="form-label">Фактическая дата завершения <span class="text-danger">*</span></label>
                                <input type="date" asp-for="Contract.ActualCompletionDate" class="form-control" id="actualCompletionDate" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Оценка исполнения <span class="text-danger">*</span></label>
                                <select asp-for="Contract.PerformanceRating" class="form-select" id="performanceRating">
                                    <option value="">— Выберите —</option>
                                    <option value="@((int)PerformanceRating.HighlySatisfactory)">⭐ Высоко удовлетворительно</option>
                                    <option value="@((int)PerformanceRating.Satisfactory)">✅ Удовлетворительно</option>
                                    <option value="@((int)PerformanceRating.Unsatisfactory)">⚠️ Неудовлетворительно</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label class="form-label">Объём работ (RU) <span class="text-danger">*</span></label>
                                <textarea asp-for="Contract.ScopeOfWork" class="form-control" id="scopeOfWork" rows="3" required></textarea>
                            </div>
                        </div>
                        
                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label class="form-label">Объём работ (TJ)</label>
                                <textarea asp-for="Contract.ScopeOfWorkTj" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Объём работ (EN)</label>
                                <textarea asp-for="Contract.ScopeOfWorkEn" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Куратор и Менеджер проекта -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-people me-2"></i>Ответственные лица</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Куратор контракта</label>
                                <input type="hidden" asp-for="Contract.CuratorId" id="curatorValue" />
                                <input type="text" id="curatorDropdown" />
                                <small class="text-muted">Отвечает за оперативный контроль</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Менеджер проекта</label>
                                <input type="hidden" asp-for="Contract.ProjectManagerId" id="pmValue" />
                                <input type="text" id="pmDropdown" />
                                <small class="text-muted">Проверяет АВР перед утверждением Директора</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Сроки</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Дата подписания <span class="text-danger">*</span></label>
                                <input type="date" asp-for="Contract.SigningDate" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Дата завершения <span class="text-danger">*</span></label>
                                <input type="date" asp-for="Contract.ContractEndDate" class="form-control" required />
                            </div>

                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-currency-dollar me-2"></i>Финансы</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Валюта контракта <span class="text-danger">*</span></label>
                                <select asp-for="Contract.Currency" class="form-select" id="contractCurrency">
                                    <option value="0">💵 USD — Доллар</option>
                                    <option value="1">🇹🇯 TJS — Сомони</option>
                                </select>
                            </div>
                            <!-- TJS mode: TJS is primary input -->
                            <div class="col-md-3" id="tjsAmountGroup" style="display: none;">
                                <label class="form-label">Сумма контракта (TJS) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">SM</span>
                                    <input type="number" asp-for="Contract.AmountTjs" class="form-control" id="contractAmountTjs" step="0.01" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3" id="tjsRateGroup" style="display: none;">
                                <label class="form-label">Курс USD/TJS</label>
                                <div class="input-group">
                                    <span class="input-group-text">📊</span>
                                    <input type="number" asp-for="Contract.ExchangeRate" class="form-control" id="contractExchangeRate" step="0.0001" readonly />
                                </div>
                                <small class="text-muted" id="rateInfo">На дату подписания</small>
                            </div>
                            <!-- USD amount: primary in USD mode, auto-calculated in TJS mode -->
                            <div class="col-md-3">
                                <label class="form-label" id="usdAmountLabel">Сумма контракта (USD) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" asp-for="Contract.ContractAmount" class="form-control" id="contractAmountUsd" step="0.01" min="0" required />
                                </div>
                            </div>
                        </div>



                        <!-- Plan comparison panel -->
                        <div id="planComparisonPanel" class="mt-3" style="display: none;">
                            <div class="border rounded p-3" id="planComparisonContent"></div>
                        </div>
                    </div>
                </div>

                <!-- Индикаторы контракта -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Индикаторы контракта</h5>
                        <button type="button" class="btn btn-sm btn-success" id="addIndicatorBtn">
                            <i class="bi bi-plus-lg"></i> Добавить индикатор
                        </button>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            <i class="bi bi-info-circle me-1"></i>
                            Укажите индикаторы, которые должен достичь подрядчик по этому контракту.
                        </p>
                        <div id="indicatorsContainer">
                            <!-- Dynamic indicator rows will be added here -->
                        </div>
                        <div id="noIndicators" class="text-center text-muted py-3">
                            <i class="bi bi-bar-chart fs-4 d-block mb-2"></i>
                            Нет добавленных индикаторов
                        </div>
                    </div>
                </div>

                <!-- Промежуточные этапы (Milestones) -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-flag me-2"></i>Промежуточные этапы</h5>
                        <button type="button" class="btn btn-sm btn-success" id="addMilestoneBtn">
                            <i class="bi bi-plus-lg"></i> Добавить этап
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="milestonesContainer"></div>
                        <div id="noMilestones" class="text-center text-muted py-3">
                            <i class="bi bi-flag fs-4 d-block mb-2"></i>
                            Нет добавленных этапов
                        </div>
                    </div>
                </div>

                <!-- Документы контракта (3 вкладки) -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-folder2-open me-2"></i>Документы</h5>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs" id="docTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#signedContent" type="button" role="tab">
                                    <i class="bi bi-file-earmark-check me-1"></i>Подписанный контракт
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#mandatoryContent" type="button" role="tab">
                                    <i class="bi bi-file-earmark-lock me-1"></i>Обязательные
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#additionalContent" type="button" role="tab">
                                    <i class="bi bi-file-earmark-plus me-1"></i>Дополнительные
                                </button>
                            </li>
                        </ul>
                        <div class="tab-content pt-3" id="docTabContent">
                            <div class="tab-pane fade show active" id="signedContent" role="tabpanel">
                                <div id="signedUploadContainer"></div>
                                <button type="button" class="btn btn-sm btn-outline-success mt-2" onclick="addDocRow('signedUploadContainer', 'SignedContractFiles', 'SignedContractNames')">
                                    <i class="bi bi-plus-lg me-1"></i>Добавить файл
                                </button>
                            </div>
                            <div class="tab-pane fade" id="mandatoryContent" role="tabpanel">
                                <div id="mandatoryUploadContainer"></div>
                                <button type="button" class="btn btn-sm btn-outline-success mt-2" onclick="addDocRow('mandatoryUploadContainer', 'MandatoryDocumentFiles', 'MandatoryDocumentNames')">
                                    <i class="bi bi-plus-lg me-1"></i>Добавить файл
                                </button>
                            </div>
                            <div class="tab-pane fade" id="additionalContent" role="tabpanel">
                                <div id="additionalUploadContainer"></div>
                                <button type="button" class="btn btn-sm btn-outline-success mt-2" onclick="addDocRow('additionalUploadContainer', 'AdditionalDocumentFiles', 'AdditionalDocumentNames')">
                                    <i class="bi bi-plus-lg me-1"></i>Добавить файл
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Создать контракт
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script id="userItemTpl" type="text/x-template">
    <div class="user-ddl-item">
        <div class="user-ddl-avatar" style="background: ${color}">${initials}</div>
        <div class="user-ddl-info">
            <span class="user-ddl-name">${name}</span>
            <span class="user-ddl-position">${position}</span>
        </div>
    </div>
</script>
<script id="userValueTpl" type="text/x-template">
    <div class="user-ddl-value">
        <div class="user-ddl-avatar" style="background: ${color}">${initials}</div>
        <span class="user-ddl-name">${name}</span>
    </div>
</script>
<script>
    // Indicator data with MeasurementType, MaxValue, and GeoDataSource
    const indicatorsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Indicators.Select(i => new { 
        i.Id, i.Code, Name = i.NameRu, Unit = i.Unit, 
        MeasurementType = (int)i.MeasurementType, 
        MaxValue = i.TargetValue,
        GeoDataSource = (int)i.GeoDataSource,
        CategoryName = i.Category != null ? i.Category.Name : ""
    })));
    let indicatorIndex = 0;
    let allocations = {}; // { indicatorId: allocatedSum }
    let villagesData = null; // will be loaded from API

    const geoSourceLabels = {
        1: '🏘️ Население',
        2: '👩 Женское население', 
        3: '🏠 Домохозяйства',
        4: '🏫 Школы',
        5: '🏥 Медучреждения',
        6: '🎓 Ученики'
    };

    const geoSourceFields = {
        1: 'population',
        2: 'femalePopulation',
        3: 'households',
        4: 'schoolCount',
        5: 'healthFacilityCount',
        6: 'schoolStudents'
    };

    // Load allocations on page load
    async function loadAllocations() {
        try {
            const resp = await fetch('/Contracts/GetIndicatorAllocations');
            const data = await resp.json();
            data.forEach(a => { allocations[a.indicatorId] = a.allocated; });
        } catch(e) { console.warn('Failed to load allocations', e); }
    }

    // Load villages data on page load
    async function loadVillagesData() {
        try {
            const resp = await fetch('/Contracts/GetVillagesData');
            villagesData = await resp.json();
        } catch(e) { console.warn('Failed to load villages data', e); }
    }

    function getAvailable(indicator) {
        if (!indicator || indicator.MaxValue == null || indicator.MaxValue == 0) return null;
        const allocated = allocations[indicator.Id] || 0;
        return Math.max(0, indicator.MaxValue - allocated);
    }

    function formatNumber(n) {
        if (n == null) return '—';
        return new Intl.NumberFormat('ru-RU').format(n);
    }

    function computeGeoValue(villageIds, geoSource) {
        if (!villagesData || !villageIds.length) return 0;
        const field = geoSourceFields[geoSource];
        if (!field) return 0;
        let total = 0;
        for (const district of villagesData) {
            for (const jamoat of district.jamoats) {
                for (const village of jamoat.villages) {
                    if (villageIds.includes(village.id)) {
                        total += village[field] || 0;
                    }
                }
            }
        }
        return total;
    }

    function buildVillagePanel(idx, geoSource, selectedVillageIds = []) {
        if (!villagesData) return '<div class="text-muted small">Загрузка данных...</div>';
        const field = geoSourceFields[geoSource];
        const label = geoSourceLabels[geoSource];
        
        let html = `<div class="village-selection-panel border rounded p-3 mt-2" style="max-height:300px; overflow-y:auto; background:#f8f9fa;">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong class="small"><i class="bi bi-geo-alt me-1"></i>Выберите сёла (${label})</strong>
                <span class="badge bg-primary village-counter-${idx}">0 выбрано</span>
            </div>`;
        
        for (const district of villagesData) {
            const distVillages = [];
            for (const jamoat of district.jamoats) {
                for (const v of jamoat.villages) distVillages.push(v);
            }
            if (distVillages.length === 0) continue;
            
            html += `<div class="mb-2">
                <div class="fw-bold small text-primary border-bottom pb-1 mb-1 d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-2 district-cb-${idx}" data-district="${district.id}" />
                    📍 ${district.name}
                </div>`;
            
            for (const jamoat of district.jamoats) {
                if (jamoat.villages.length === 0) continue;
                html += `<div class="ms-3 mb-1">
                    <div class="small text-muted d-flex align-items-center">
                        <input type="checkbox" class="form-check-input me-2 jamoat-cb-${idx}" data-jamoat="${jamoat.id}" data-district="${district.id}" />
                        ${jamoat.name}
                    </div>`;
                for (const v of jamoat.villages) {
                    const checked = selectedVillageIds.includes(v.id) ? 'checked' : '';
                    const val = v[field] || 0;
                    html += `<div class="ms-3 d-flex align-items-center">
                        <input type="checkbox" class="form-check-input me-1 village-cb-${idx}" 
                               name="SelectedIndicators[${idx}].VillageIds" value="${v.id}" 
                               data-jamoat="${jamoat.id}" data-district="${district.id}" data-val="${val}" ${checked} />
                        <span class="small">${v.name}</span>
                        <span class="badge bg-light text-dark ms-auto small">${formatNumber(val)}</span>
                    </div>`;
                }
                html += '</div>';
            }
            html += '</div>';
        }
        
        html += `<div class="mt-2 pt-2 border-top">
            <strong class="small">Итого: <span class="geo-total-${idx} text-success">0</span></strong>
        </div></div>`;
        return html;
    }

    function addIndicatorRow(indicatorId = '', targetValue = '', notes = '') {
        const container = document.getElementById('indicatorsContainer');
        const noIndicators = document.getElementById('noIndicators');
        noIndicators.style.display = 'none';

        const row = document.createElement('div');
        row.className = 'row g-3 mb-3 indicator-row align-items-end p-2 border rounded bg-light';
        
        const idx = indicatorIndex;
        
        row.innerHTML = `
            <div class="col-md-5">
                <label class="form-label fw-semibold">Индикатор</label>
                <select name="SelectedIndicators[${idx}].IndicatorId" class="form-select indicator-select" required>
                    <option value="">— Выберите индикатор —</option>
                    ${indicatorsData.map(i => `<option value="${i.Id}" ${i.Id == indicatorId ? 'selected' : ''} 
                        data-type="${i.MeasurementType}" data-max="${i.MaxValue ?? ''}" 
                        data-geo="${i.GeoDataSource}"
                        data-category="${i.CategoryName}">${i.Code} - ${i.Name}</option>`).join('')}
                </select>
            </div>
            <div class="col-md-3 target-col">
                <label class="form-label fw-semibold">Целевое значение <span class="text-danger">*</span></label>
                <input type="number" name="SelectedIndicators[${idx}].TargetValue" class="form-control target-input" 
                       value="${targetValue}" step="0.01" min="0.01" placeholder="0.00" required />
                <div class="indicator-info mt-1" style="display:none;"></div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Примечание</label>
                <input type="text" name="SelectedIndicators[${idx}].Notes" class="form-control" 
                       value="${notes}" placeholder="Описание..." />
            </div>
            <div class="col-md-1 text-center">
                <button type="button" class="btn btn-outline-danger btn-sm remove-indicator-btn" title="Удалить">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            <div class="col-12 village-panel-container" style="display:none;"></div>
        `;
        container.appendChild(row);
        indicatorIndex++;

        const select = row.querySelector('.indicator-select');
        const targetCol = row.querySelector('.target-col');
        const targetInput = row.querySelector('.target-input');
        const infoDiv = row.querySelector('.indicator-info');
        const villagePanelContainer = row.querySelector('.village-panel-container');

        function updateIndicatorUI() {
            const opt = select.selectedOptions[0];
            if (!opt || !opt.value) {
                targetCol.style.display = '';
                targetInput.type = 'number';
                targetInput.required = true;
                targetInput.removeAttribute('max');
                infoDiv.style.display = 'none';
                villagePanelContainer.style.display = 'none';
                villagePanelContainer.innerHTML = '';
                return;
            }
            const mType = parseInt(opt.dataset.type);
            const maxVal = opt.dataset.max ? parseFloat(opt.dataset.max) : null;
            const geoSource = parseInt(opt.dataset.geo || '0');
            const indicator = indicatorsData.find(i => i.Id == opt.value);
            
            if (mType === 2) {
                // YesNo — hide number input, show badge
                targetInput.type = 'hidden';
                targetInput.value = '1';
                targetInput.required = false;
                targetInput.removeAttribute('max');
                infoDiv.innerHTML = '<span class="badge bg-info fs-6"><i class="bi bi-toggle-on me-1"></i>Качественный (Да/Нет)</span>';
                infoDiv.style.display = 'block';
                targetCol.querySelector('.form-label').style.display = 'none';
                villagePanelContainer.style.display = 'none';
                villagePanelContainer.innerHTML = '';
            } else {
                // Number or Percentage
                targetInput.type = 'number';
                targetInput.required = true;
                targetCol.querySelector('.form-label').style.display = '';
                
                if (maxVal != null && maxVal > 0) {
                    const available = getAvailable(indicator);
                    const unit = mType === 1 ? '%' : '';
                    if (available != null) {
                        targetInput.max = available;
                        infoDiv.innerHTML = `
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>Макс: <strong>${formatNumber(maxVal)}${unit}</strong> · 
                                Доступно: <strong class="${available <= 0 ? 'text-danger' : 'text-success'}">${formatNumber(available)}${unit}</strong>
                            </small>`;
                    } else {
                        targetInput.removeAttribute('max');
                        infoDiv.innerHTML = `<small class="text-muted"><i class="bi bi-info-circle me-1"></i>Макс: <strong>${formatNumber(maxVal)}${unit}</strong></small>`;
                    }
                    infoDiv.style.display = 'block';
                } else {
                    targetInput.removeAttribute('max');
                    infoDiv.style.display = 'none';
                }
                
                // Show village selection panel for geo-linked indicators
                if (geoSource > 0 && villagesData) {
                    villagePanelContainer.innerHTML = buildVillagePanel(idx, geoSource);
                    villagePanelContainer.style.display = '';
                    setupVillageCheckboxes(idx, geoSource, targetInput);
                } else {
                    villagePanelContainer.style.display = 'none';
                    villagePanelContainer.innerHTML = '';
                }
            }
        }

        select.addEventListener('change', updateIndicatorUI);
        // Trigger on load if pre-selected
        if (indicatorId) updateIndicatorUI();

        // Remove button handler
        row.querySelector('.remove-indicator-btn').addEventListener('click', function() {
            row.remove();
            if (container.children.length === 0) {
                noIndicators.style.display = 'block';
            }
        });
    }

    function setupVillageCheckboxes(idx, geoSource, targetInput) {
        const villageCbs = document.querySelectorAll(`.village-cb-${idx}`);
        const districtCbs = document.querySelectorAll(`.district-cb-${idx}`);
        const jamoatCbs = document.querySelectorAll(`.jamoat-cb-${idx}`);
        const counter = document.querySelector(`.village-counter-${idx}`);
        const totalSpan = document.querySelector(`.geo-total-${idx}`);

        function updateTotal() {
            let total = 0;
            let count = 0;
            villageCbs.forEach(cb => {
                if (cb.checked) {
                    total += parseFloat(cb.dataset.val) || 0;
                    count++;
                }
            });
            if (counter) counter.textContent = `${count} выбрано`;
            if (totalSpan) totalSpan.textContent = formatNumber(total);
            // Auto-fill target value from geo total
            targetInput.value = total;
        }

        villageCbs.forEach(cb => cb.addEventListener('change', () => {
            updateTotal();
            // Update jamoat/district parent checkboxes
            updateParentCheckboxes(idx, cb.dataset.jamoat, cb.dataset.district);
        }));

        // District-level "select all"
        districtCbs.forEach(dcb => dcb.addEventListener('change', () => {
            const distId = dcb.dataset.district;
            villageCbs.forEach(cb => { if (cb.dataset.district == distId) cb.checked = dcb.checked; });
            jamoatCbs.forEach(jcb => { if (jcb.dataset.district == distId) jcb.checked = dcb.checked; });
            updateTotal();
        }));

        // Jamoat-level "select all"
        jamoatCbs.forEach(jcb => jcb.addEventListener('change', () => {
            const jamId = jcb.dataset.jamoat;
            villageCbs.forEach(cb => { if (cb.dataset.jamoat == jamId) cb.checked = jcb.checked; });
            updateTotal();
            // Update district parent
            updateDistrictCheckbox(idx, jcb.dataset.district);
        }));

        // Initial calculation for pre-selected villages
        updateTotal();
    }

    function updateParentCheckboxes(idx, jamoatId, districtId) {
        // Update jamoat checkbox
        const jamCbs = document.querySelectorAll(`.village-cb-${idx}[data-jamoat="${jamoatId}"]`);
        const jamParent = document.querySelector(`.jamoat-cb-${idx}[data-jamoat="${jamoatId}"]`);
        if (jamParent) {
            const allChecked = [...jamCbs].every(cb => cb.checked);
            jamParent.checked = allChecked;
        }
        updateDistrictCheckbox(idx, districtId);
    }

    function updateDistrictCheckbox(idx, districtId) {
        const distCbs = document.querySelectorAll(`.village-cb-${idx}[data-district="${districtId}"]`);
        const distParent = document.querySelector(`.district-cb-${idx}[data-district="${districtId}"]`);
        if (distParent) {
            const allChecked = [...distCbs].every(cb => cb.checked);
            distParent.checked = allChecked;
        }
    }

    document.getElementById('addIndicatorBtn').addEventListener('click', function() {
        addIndicatorRow();
    });

    // ProcurementType -> ContractType mapping
    // ProcurementType: Goods=0, Works=1, ConsultingServices=2, NonConsultingServices=3
    // ContractType: Works=0, Consulting=1, Goods=2
    const procTypeToContractType = { 0: 2, 1: 0, 2: 1, 3: 1 };

    // Filter procurement plans by selected project
    document.getElementById('projectSelect').addEventListener('change', function() {
        const projectId = this.value;
        const procPlanSelect = document.getElementById('procurementPlanSelect');
        
        // Filter procurement plans by project
        procPlanSelect.querySelectorAll('option[data-project]').forEach(opt => {
            opt.style.display = (!projectId || opt.dataset.project === projectId) ? '' : 'none';
        });
        if (procPlanSelect.selectedOptions[0]?.style.display === 'none') {
            procPlanSelect.value = '';
        }
        
        // Reset component and subcomponent when project changes
        const componentSelect = document.getElementById('componentSelect');
        componentSelect.innerHTML = '<option value="">— Заполняется из плана закупок —</option>';
        document.getElementById('subComponentSelect').innerHTML = '<option value="">— Необязательно —</option>';
    });

    // Auto-fill from procurement plan
    document.getElementById('procurementPlanSelect').addEventListener('change', async function() {
        const planId = this.value;
        if (!planId) return;
        
        try {
            const resp = await fetch(`/Contracts/GetProcurementPlanData?id=${planId}`);
            if (!resp.ok) return;
            const data = await resp.json();
            
            // Fill contract number from reference number
            const contractNumInput = document.getElementById('contractNumber');
            if (contractNumInput && data.referenceNo) {
                contractNumInput.value = data.referenceNo;
            }
            
            // Map procurement type to contract type
            const contractTypeSelect = document.getElementById('contractType');
            if (contractTypeSelect && data.type !== undefined) {
                const mappedType = procTypeToContractType[data.type];
                if (mappedType !== undefined) {
                    contractTypeSelect.value = mappedType;
                }
            }
            
            // Fill scope of work from description
            const scopeInput = document.getElementById('scopeOfWork');
            if (scopeInput && data.description) {
                scopeInput.value = data.description;
            }

            // Store plan estimated amount and show comparison
            planEstimatedAmount = data.estimatedAmount || 0;
            planReferenceNo = data.referenceNo || '';
            updatePlanComparison();
            
            // Auto-select project
            if (data.projectId) {
                const projSelect = document.getElementById('projectSelect');
                projSelect.value = data.projectId;
            }
            
            // Auto-fill component (display only)
            const componentSelect = document.getElementById('componentSelect');
            componentSelect.innerHTML = '<option value="">— Нет компонента —</option>';
            if (data.componentId && data.componentName) {
                componentSelect.innerHTML = `<option value="${data.componentId}" selected>${data.componentName}</option>`;
            }
            
            // Auto-fill subcomponent
            const subComponentSelect = document.getElementById('subComponentSelect');
            subComponentSelect.innerHTML = '<option value="">— Необязательно —</option>';
            if (data.subComponentId && data.subComponentName) {
                subComponentSelect.innerHTML += `<option value="${data.subComponentId}" selected>${data.subComponentName}</option>`;
            }
        } catch(e) {
            console.warn('Failed to load procurement plan data', e);
        }
    });

    // Load data on page load
    document.addEventListener('DOMContentLoaded', async function() {
        await Promise.all([loadAllocations(), loadVillagesData()]);
    });

    // ========================
    // Milestones Management
    // ========================
    let milestoneIndex = 0;
    const frequencies = [
        { value: 0, label: 'Разовый' },
        { value: 1, label: 'Месячный' },
        { value: 2, label: 'Квартальный' },
        { value: 3, label: 'Полугодовой' },
        { value: 4, label: 'Годовой' }
    ];

    function addMilestoneRow(data = {}) {
        const container = document.getElementById('milestonesContainer');
        document.getElementById('noMilestones').style.display = 'none';

        const row = document.createElement('div');
        row.className = 'row g-2 mb-3 milestone-row align-items-end p-2 border rounded bg-light';
        row.innerHTML = `
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Название (RU)</label>
                <input type="text" class="form-control milestone-title" value="${data.title || ''}" required />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Срок</label>
                <input type="date" class="form-control milestone-date" value="${data.dueDate || ''}" required />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Периодичность</label>
                <select class="form-select milestone-freq">
                    ${frequencies.map(f => `<option value="${f.value}" ${f.value == (data.frequency ?? 0) ? 'selected' : ''}>${f.label}</option>`).join('')}
                </select>
            </div>
            <div class="col-md-2 text-center">
                <button type="button" class="btn btn-outline-danger btn-sm remove-milestone-btn">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            <div class="col-md-6 mt-2">
                <input type="text" class="form-control form-control-sm milestone-title-tj" value="${data.titleTj || ''}" placeholder="Название (TJ)" />
            </div>
            <div class="col-md-6 mt-2">
                <input type="text" class="form-control form-control-sm milestone-title-en" value="${data.titleEn || ''}" placeholder="Title (EN)" />
            </div>
            <div class="col-12 mt-1">
                <textarea class="form-control form-control-sm milestone-desc" rows="1" placeholder="Описание...">${data.description || ''}</textarea>
            </div>
        `;
        container.appendChild(row);
        milestoneIndex++;

        row.querySelector('.remove-milestone-btn').addEventListener('click', () => {
            row.remove();
            if (container.children.length === 0) document.getElementById('noMilestones').style.display = 'block';
            collectMilestones();
        });

        // Collect on any change
        row.querySelectorAll('input, select, textarea').forEach(el => el.addEventListener('change', collectMilestones));
    }

    function collectMilestones() {
        const rows = document.querySelectorAll('.milestone-row');
        const milestones = [];
        let order = 0;
        rows.forEach(row => {
            milestones.push({
                title: row.querySelector('.milestone-title')?.value || '',
                titleTj: row.querySelector('.milestone-title-tj')?.value || '',
                titleEn: row.querySelector('.milestone-title-en')?.value || '',
                description: row.querySelector('.milestone-desc')?.value || '',
                dueDate: row.querySelector('.milestone-date')?.value || '',
                frequency: parseInt(row.querySelector('.milestone-freq')?.value) || 0,
                sortOrder: order++
            });
        });
        document.getElementById('milestonesJson').value = JSON.stringify(milestones);
    }

    document.getElementById('addMilestoneBtn').addEventListener('click', () => addMilestoneRow());

    // Collect milestones before form submit
    document.querySelector('form').addEventListener('submit', collectMilestones);

    // === Currency selector logic ===
    const currencySelect = document.getElementById('contractCurrency');
    const tjsRateGroup = document.getElementById('tjsRateGroup');
    const tjsAmountGroup = document.getElementById('tjsAmountGroup');
    const contractAmountUsd = document.getElementById('contractAmountUsd');
    const contractExchangeRate = document.getElementById('contractExchangeRate');
    const contractAmountTjs = document.getElementById('contractAmountTjs');
    const signingDateInput = document.getElementById('Contract_SigningDate');
    const rateInfo = document.getElementById('rateInfo');

    function toggleCurrencyFields() {
        const isTjs = currencySelect.value === '1';
        tjsRateGroup.style.display = isTjs ? '' : 'none';
        tjsAmountGroup.style.display = isTjs ? '' : 'none';
        if (isTjs) {
            // TJS mode: TJS is editable, USD is calculated
            contractAmountTjs.removeAttribute('readonly');
            contractAmountTjs.setAttribute('required', 'required');
            contractAmountUsd.setAttribute('readonly', 'readonly');
            contractAmountUsd.removeAttribute('required');
            document.getElementById('usdAmountLabel').innerHTML = 'Сумма (USD) <small class="text-muted">авто</small>';
            fetchRate();
        } else {
            // USD mode: USD is editable, no TJS fields
            contractAmountUsd.removeAttribute('readonly');
            contractAmountUsd.setAttribute('required', 'required');
            document.getElementById('usdAmountLabel').innerHTML = 'Сумма контракта (USD) <span class="text-danger">*</span>';
            contractExchangeRate.value = '';
            contractAmountTjs.value = '';
        }
    }

    async function fetchRate() {
        const dateVal = signingDateInput?.value;
        if (!dateVal) {
            rateInfo.textContent = 'Укажите дату подписания';
            return;
        }
        rateInfo.innerHTML = '<i class="bi bi-hourglass-split"></i> Загрузка курса...';
        try {
            const resp = await fetch(`/Currency/GetUsdRate?date=${dateVal}`);
            const data = await resp.json();
            if (data.rate) {
                contractExchangeRate.value = data.rate;
                rateInfo.textContent = `Курс НБТ на ${dateVal}`;
                calculateUsdFromTjs();
            } else {
                rateInfo.textContent = 'Курс недоступен на эту дату';
            }
        } catch (e) {
            rateInfo.textContent = 'Ошибка загрузки курса';
        }
    }

    function calculateUsdFromTjs() {
        const tjs = parseFloat(contractAmountTjs.value) || 0;
        const rate = parseFloat(contractExchangeRate.value) || 0;
        contractAmountUsd.value = rate > 0 ? (tjs / rate).toFixed(2) : '';
        updatePlanComparison();
    }

    currencySelect.addEventListener('change', () => { toggleCurrencyFields(); updatePlanComparison(); });
    if (signingDateInput) signingDateInput.addEventListener('change', () => { if (currencySelect.value === '1') fetchRate(); });
    contractAmountTjs.addEventListener('input', calculateUsdFromTjs);
    contractAmountUsd.addEventListener('input', updatePlanComparison);

    // === Plan comparison logic ===
    let planEstimatedAmount = 0;
    let planReferenceNo = '';

    function fmtUsd(n) { return '$' + new Intl.NumberFormat('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n); }

    function updatePlanComparison() {
        const panel = document.getElementById('planComparisonPanel');
        const content = document.getElementById('planComparisonContent');
        if (!planEstimatedAmount || planEstimatedAmount <= 0) {
            panel.style.display = 'none';
            return;
        }

        const contractUsd = parseFloat(contractAmountUsd.value) || 0;
        const isTjs = currencySelect.value === '1';
        const rate = parseFloat(contractExchangeRate.value) || 0;

        let html = `<div class="d-flex align-items-center gap-3 mb-2">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6">
                <i class="bi bi-clipboard-data me-1"></i>План: <strong>${fmtUsd(planEstimatedAmount)}</strong>
            </span>`;

        if (isTjs && rate > 0) {
            const planTjs = planEstimatedAmount * rate;
            html += `<span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2">
                ≈ ${new Intl.NumberFormat('ru-RU', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(planTjs)} TJS (курс: ${rate.toFixed(4)})
            </span>`;
        }
        html += `</div>`;

        if (contractUsd > 0) {
            const diff = contractUsd - planEstimatedAmount;
            const diffPercent = ((diff / planEstimatedAmount) * 100).toFixed(1);

            if (diff > 0) {
                html += `<div class="alert alert-danger mb-0 py-2">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Превышение плана!</strong> Сумма контракта превышает план на 
                    <strong>${fmtUsd(Math.abs(diff))}</strong> (+${Math.abs(diffPercent)}%)
                </div>`;
            } else if (diff < 0) {
                html += `<div class="alert alert-success mb-0 py-2">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Сумма ниже плана на <strong>${fmtUsd(Math.abs(diff))}</strong> (${Math.abs(diffPercent)}% экономия)
                </div>`;
            } else {
                html += `<div class="alert alert-info mb-0 py-2">
                    <i class="bi bi-check-circle me-2"></i>
                    Сумма контракта совпадает с планом
                </div>`;
            }
        } else {
            html += `<div class="text-muted small"><i class="bi bi-info-circle me-1"></i>Введите сумму контракта для сравнения</div>`;
        }

        content.innerHTML = html;
        panel.style.display = '';
    }

    // === Restore form state after validation failure ===
    // 1. Restore TJS fields visibility
    toggleCurrencyFields();

    // 2. Restore previously added indicators
    const savedIndicators = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedIndicators ?? new List<PMMIS.Web.ViewModels.Contracts.ContractIndicatorInput>()));
    if (savedIndicators && savedIndicators.length > 0) {
        loadAllocations().then(() => {
            loadVillagesData().then(() => {
                savedIndicators.forEach(si => {
                    addIndicatorRow(si.indicatorId || si.IndicatorId, si.targetValue || si.TargetValue, si.notes || si.Notes || '');
                });
            });
        });
    }

    // 3. Restore previously added milestones
    const savedMilestonesJson = document.getElementById('milestonesJson')?.value;
    if (savedMilestonesJson) {
        try {
            const savedMilestones = JSON.parse(savedMilestonesJson);
            if (savedMilestones && savedMilestones.length > 0) {
                savedMilestones.forEach(m => addMilestoneRow(m));
            }
        } catch(e) { console.warn('Failed to restore milestones', e); }
    }

    // === Syncfusion DropDownList for Curator and PM ===
    const avatarColors = ['#4e79a7','#f28e2b','#e15759','#76b7b2','#59a14f','#edc948','#b07aa1','#ff9da7','#9c755f','#bab0ac'];
    function getInitials(name) {
        if (!name) return '?';
        const parts = name.trim().split(/\s+/);
        return parts.length >= 2 ? (parts[0][0] + parts[1][0]) : parts[0].substring(0, 2);
    }
    function getColor(name) {
        let hash = 0;
        for (let i = 0; i < (name || '').length; i++) hash = name.charCodeAt(i) + ((hash << 5) - hash);
        return avatarColors[Math.abs(hash) % avatarColors.length];
    }

    const usersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Users.Select(u => new { id = u.Id, name = u.FullName, position = u.Position ?? "" }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
    ));
    const usersDdlData = usersData.map(u => ({ ...u, initials: getInitials(u.name), color: getColor(u.name) }));

    function initUserDropdown(inputId, hiddenId, placeholder) {
        const el = document.getElementById(inputId);
        const currentVal = document.getElementById(hiddenId).value;
        if (!el) return;
        const ddl = new ej.dropdowns.DropDownList({
            dataSource: usersDdlData,
            fields: { value: 'id', text: 'name' },
            placeholder: placeholder,
            popupHeight: '280px',
            allowFiltering: true,
            filterBarPlaceholder: '\u041f\u043e\u0438\u0441\u043a \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0430...',
            showClearButton: true,
            itemTemplate: document.getElementById('userItemTpl').innerHTML,
            valueTemplate: document.getElementById('userValueTpl').innerHTML,
            value: currentVal || null,
            change: function(args) {
                document.getElementById(hiddenId).value = args.value || '';
            }
        });
        ddl.appendTo(el);
    }

    initUserDropdown('curatorDropdown', 'curatorValue', '\u2014 \u041d\u0435 \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d \u2014');
    initUserDropdown('pmDropdown', 'pmValue', '\u2014 \u041d\u0435 \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d \u2014');

    // === Document upload rows ===
    function addDocRow(containerId, fileFieldName, nameFieldName) {
        const container = document.getElementById(containerId);
        const row = document.createElement('div');
        row.className = 'row g-2 mb-2 align-items-end doc-upload-row';
        row.innerHTML = `
            <div class="col-md-5">
                <input type="text" name="${nameFieldName}" class="form-control form-control-sm" placeholder="Название документа" />
            </div>
            <div class="col-md-6">
                <input type="file" name="${fileFieldName}" class="form-control form-control-sm" 
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" required />
            </div>
            <div class="col-md-1 text-center">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.doc-upload-row').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
    }

    // === Contract Status toggle ===
    const statusSelect = document.getElementById('contractStatusSelect');
    const completionRow = document.getElementById('completionFieldsRow');
    const completionDate = document.getElementById('actualCompletionDate');
    const perfRating = document.getElementById('performanceRating');

    function toggleCompletionFields() {
        const isCompleted = statusSelect.value === '@((int)ContractStatus.Completed)';
        completionRow.style.display = isCompleted ? 'flex' : 'none';
        if (completionDate) completionDate.required = isCompleted;
        if (perfRating) perfRating.required = isCompleted;
        if (!isCompleted) {
            if (completionDate) completionDate.value = '';
            if (perfRating) perfRating.value = '';
        }
    }

    if (statusSelect) {
        statusSelect.addEventListener('change', toggleCompletionFields);
    }
</script>
}

