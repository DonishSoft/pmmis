@{
    ViewData["Title"] = "Цепочка утверждений";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-arrow-repeat me-2"></i>Цепочка утверждений</h2>
            <p class="text-muted mb-0">Настройка маршрута утверждения АВР и платежей по ролям</p>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-avr" type="button">
                <i class="bi bi-file-earmark-check me-1"></i> АВР
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-payment" type="button">
                <i class="bi bi-credit-card me-1"></i> Платежи
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- ═══ AVR Tab ═══ -->
        <div class="tab-pane fade show active" id="tab-avr" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-0 rounded-bottom">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        При отказе документ вернётся на указанный шаг (пусто = на 1-й)
                    </span>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="addStep('AVR')">
                            <i class="bi bi-plus-lg me-1"></i>Добавить шаг
                        </button>
                        <button class="btn btn-sm btn-primary" onclick="saveWorkflow('AVR')">
                            <i class="bi bi-check-lg me-1"></i>Сохранить
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="avr-grid"></div>
                </div>
            </div>
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white py-2">
                    <strong><i class="bi bi-signpost-2 me-2"></i>Визуальная схема</strong>
                </div>
                <div class="card-body" id="avr-flow" style="min-height: 60px;"></div>
            </div>
        </div>

        <!-- ═══ Payment Tab ═══ -->
        <div class="tab-pane fade" id="tab-payment" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-0 rounded-bottom">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                    <span class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        При отказе документ вернётся на указанный шаг (пусто = на 1-й)
                    </span>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="addStep('Payment')">
                            <i class="bi bi-plus-lg me-1"></i>Добавить шаг
                        </button>
                        <button class="btn btn-sm btn-primary" onclick="saveWorkflow('Payment')">
                            <i class="bi bi-check-lg me-1"></i>Сохранить
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="payment-grid"></div>
                </div>
            </div>
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white py-2">
                    <strong><i class="bi bi-signpost-2 me-2"></i>Визуальная схема</strong>
                </div>
                <div class="card-body" id="payment-flow" style="min-height: 60px;"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .flow-container { display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; padding: 8px 0; }
    .flow-step {
        position: relative; background: linear-gradient(135deg, #f8f9ff, #eef2ff);
        border: 2px solid #6366f1; border-radius: 12px; padding: 14px 18px;
        min-width: 150px; max-width: 200px; text-align: center; transition: all 0.2s;
    }
    .flow-step:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99,102,241,0.2); }
    .flow-step .step-num {
        position: absolute; top: -10px; left: -10px; width: 24px; height: 24px;
        background: #6366f1; color: #fff; border-radius: 50%; font-size: 12px;
        font-weight: 700; display: flex; align-items: center; justify-content: center;
    }
    .flow-step .step-icon { font-size: 22px; display: block; margin-bottom: 2px; }
    .flow-step .step-title { font-weight: 600; font-size: 13px; color: #1e293b; }
    .flow-step .step-role { font-size: 11px; color: #64748b; margin-top: 2px; }
    .flow-arrow { display: flex; flex-direction: column; align-items: center; align-self: center; color: #22c55e; font-size: 20px; font-weight: 700; }
    .flow-reject-badge {
        font-size: 10px; background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5;
        border-radius: 6px; padding: 2px 8px; display: inline-flex; align-items: center; gap: 3px; margin-top: 4px;
    }
    .e-grid .e-headercell { background: #f1f5f9 !important; font-weight: 600 !important; }
</style>

@section Scripts {
<script>
    // ─── Data ───
    const rolesData = @Html.Raw(ViewBag.RolesJson);
    let avrData = @Html.Raw(ViewBag.AvrStepsJson);
    let paymentData = @Html.Raw(ViewBag.PaymentStepsJson);

    const actionTypesList = [
        { value: 'Create', text: '📝 Создание' },
        { value: 'Review', text: '👁️ Проверка' },
        { value: 'Approve', text: '✅ Утверждение' },
        { value: 'FinalApprove', text: '🏆 Финальное утверждение' }
    ];

    const actionIcons = { 'Create': '📝', 'Review': '👁️', 'Approve': '✅', 'FinalApprove': '🏆' };
    const actionLabels = { 'Create': 'Создание', 'Review': 'Проверка', 'Approve': 'Утверждение', 'FinalApprove': 'Финал' };

    // ─── Custom edit templates for DropDownList (fixes "No records found" bug) ───
    let actionTypeDropdown, roleDropdown;

    const actionTypeEditParams = {
        create: function() { return document.createElement('input'); },
        read: function() { return actionTypeDropdown ? actionTypeDropdown.value : ''; },
        destroy: function() { if (actionTypeDropdown) actionTypeDropdown.destroy(); },
        write: function(args) {
            actionTypeDropdown = new ej.dropdowns.DropDownList({
                dataSource: actionTypesList,
                fields: { value: 'value', text: 'text' },
                value: args.rowData.actionType || 'Review',
                placeholder: 'Выберите действие',
                floatLabelType: 'Always'
            });
            actionTypeDropdown.appendTo(args.element);
        }
    };

    const roleEditParams = {
        create: function() { return document.createElement('input'); },
        read: function() { return roleDropdown ? roleDropdown.value : ''; },
        destroy: function() { if (roleDropdown) roleDropdown.destroy(); },
        write: function(args) {
            roleDropdown = new ej.dropdowns.DropDownList({
                dataSource: rolesData,
                fields: { value: 'id', text: 'name' },
                value: args.rowData.roleId || (rolesData.length > 0 ? rolesData[0].id : ''),
                placeholder: 'Выберите роль',
                floatLabelType: 'Always'
            });
            roleDropdown.appendTo(args.element);
        }
    };

    // ─── Create Grid ───
    function createWorkflowGrid(elementId, data, type) {
        const grid = new ej.grids.Grid({
            dataSource: data,
            allowRowDragAndDrop: true,
            editSettings: {
                allowEditing: true,
                allowAdding: true,
                allowDeleting: true,
                mode: 'Dialog',
                showDeleteConfirmDialog: true
            },
            columns: [
                {
                    field: 'stepOrder', headerText: '№', width: 60, textAlign: 'Center',
                    isPrimaryKey: true, allowEditing: false,
                    template: '<span class="badge bg-primary rounded-pill">${stepOrder}</span>'
                },
                {
                    field: 'stepName', headerText: 'Название шага', width: 200,
                    validationRules: { required: true }
                },
                {
                    field: 'actionType', headerText: 'Тип действия', width: 160,
                    edit: actionTypeEditParams,
                    template: function(d) {
                        return (actionIcons[d.actionType] || '📋') + ' ' + (actionLabels[d.actionType] || d.actionType);
                    }
                },
                {
                    field: 'roleId', headerText: 'Роль', width: 180,
                    edit: roleEditParams,
                    template: function(d) {
                        const r = rolesData.find(x => x.id === d.roleId);
                        return '<i class="bi bi-person-badge me-1"></i>' + (r ? r.name : d.roleName || '—');
                    }
                },
                {
                    field: 'canReject', headerText: 'Может отклонить', width: 130, textAlign: 'Center',
                    displayAsCheckBox: true, editType: 'booleanedit', type: 'boolean'
                },
                {
                    field: 'rejectToStepOrder', headerText: 'Откл. → шаг №', width: 130, textAlign: 'Center',
                    editType: 'numericedit',
                    edit: { params: { min: 1, step: 1, decimals: 0, format: 'n0', placeholder: '1' } },
                    template: function(d) {
                        if (!d.canReject) return '<span class="text-muted">—</span>';
                        return '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle">↩ шаг ' + (d.rejectToStepOrder || 1) + '</span>';
                    }
                },
                {
                    headerText: '', width: 100, textAlign: 'Center',
                    commands: [
                        { type: 'Edit', buttonOption: { cssClass: 'e-flat', iconCss: 'e-edit e-icons' } },
                        { type: 'Delete', buttonOption: { cssClass: 'e-flat', iconCss: 'e-delete e-icons' } }
                    ]
                }
            ],
            actionComplete: function(args) {
                if (args.requestType === 'save' || args.requestType === 'delete') {
                    setTimeout(() => { renumberGrid(grid, type); updateFlow(type); }, 50);
                }
            },
            rowDrop: function(args) {
                // After drag-and-drop, renumber all steps
                args.cancel = true; // Cancel default to handle manually
                const data = grid.dataSource;
                const fromIndex = args.fromIndex;
                const dropIndex = args.dropIndex;
                if (fromIndex === dropIndex) return;
                // Move the dragged item
                const moved = data.splice(fromIndex, 1)[0];
                data.splice(dropIndex, 0, moved);
                // Renumber
                for (let i = 0; i < data.length; i++) data[i].stepOrder = i + 1;
                grid.dataSource = [...data];
                grid.refresh();
                setTimeout(() => updateFlow(type), 100);
            },
            dataBound: function() { updateFlow(type); },
            height: 'auto',
            gridLines: 'Horizontal',
            allowSelection: true,
            selectionSettings: { type: 'Single' }
        });
        grid.appendTo('#' + elementId);
        return grid;
    }

    // ─── Add Step (appends at end) ───
    function addStep(type) {
        const grid = type === 'AVR' ? avrGrid : paymentGrid;
        const src = grid.dataSource || [];
        const next = src.length > 0 ? Math.max(...src.map(s => s.stepOrder)) + 1 : 1;
        const newStep = {
            stepOrder: next,
            stepName: '',
            actionType: 'Review',
            roleId: rolesData.length > 0 ? rolesData[0].id : '',
            roleName: rolesData.length > 0 ? rolesData[0].name : '',
            canReject: true,
            rejectToStepOrder: null,
            isActive: true
        };
        // Push to end of dataSource and refresh (addRecord inserts at index 0)
        src.push(newStep);
        grid.dataSource = [...src];
        grid.refresh();
        // Open edit dialog for the new row
        setTimeout(() => {
            grid.selectRow(src.length - 1);
            grid.startEdit();
        }, 200);
    }

    // ─── Renumber ───
    function renumberGrid(grid, type) {
        const data = grid.dataSource;
        if (!data) return;
        for (let i = 0; i < data.length; i++) data[i].stepOrder = i + 1;
        grid.refresh();
    }

    // ─── Visual Flow ───
    function updateFlow(type) {
        const el = document.getElementById(type.toLowerCase() === 'avr' ? 'avr-flow' : 'payment-flow');
        const grid = type === 'AVR' ? avrGrid : paymentGrid;
        const data = grid ? grid.dataSource : [];
        if (!data || data.length === 0) {
            el.innerHTML = '<div class="text-center text-muted py-3"><i class="bi bi-inbox fs-3 d-block mb-1"></i>Нет шагов — нажмите «Добавить шаг»</div>';
            return;
        }
        let html = '<div class="flow-container">';
        data.forEach((s, i) => {
            const role = rolesData.find(r => r.id === s.roleId);
            const icon = actionIcons[s.actionType] || '📋';
            const reject = s.canReject ? (s.rejectToStepOrder || 1) : null;
            html += `<div class="flow-step">
                <span class="step-num">${s.stepOrder}</span>
                <span class="step-icon">${icon}</span>
                <div class="step-title">${s.stepName || 'Шаг ' + s.stepOrder}</div>
                <div class="step-role">${role ? role.name : s.roleName || '—'}</div>
                ${reject !== null ? `<span class="flow-reject-badge"><i class="bi bi-x-circle"></i> Отказ → шаг ${reject}</span>` : ''}
            </div>`;
            if (i < data.length - 1) html += `<div class="flow-arrow"><i class="bi bi-arrow-right"></i></div>`;
        });
        html += '</div>';
        el.innerHTML = html;
    }

    // ─── Save ───
    async function saveWorkflow(type) {
        const grid = type === 'AVR' ? avrGrid : paymentGrid;
        const data = grid.dataSource;
        if (!data || data.length === 0) { showToast('Добавьте хотя бы один шаг', 'warning'); return; }

        for (const s of data) {
            if (!s.stepName || !s.stepName.trim()) { showToast('Заполните названия всех шагов', 'warning'); return; }
            if (!s.roleId) { showToast('Выберите роль для каждого шага', 'warning'); return; }
        }

        const steps = data.map(s => ({
            StepName: s.stepName, ActionType: s.actionType, RoleId: s.roleId,
            CanReject: s.canReject, RejectToStepOrder: s.rejectToStepOrder
        }));

        try {
            const resp = await fetch('@Url.Action("Save")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ WorkflowType: type, Steps: steps })
            });
            const result = await resp.json();
            showToast(result.success ? result.message : ('Ошибка: ' + (result.message || '')), result.success ? 'success' : 'danger');
        } catch (e) { console.error(e); showToast('Ошибка сети', 'danger'); }
    }

    // ─── Toast ───
    function showToast(msg, type) {
        document.querySelector('.wf-toast')?.remove();
        const icons = { success: 'check-circle', warning: 'exclamation-triangle', danger: 'x-circle' };
        const t = document.createElement('div');
        t.className = 'wf-toast alert alert-' + type + ' alert-dismissible fade show position-fixed shadow-lg';
        t.style.cssText = 'top:20px;right:20px;z-index:99999;min-width:300px;';
        t.innerHTML = `<i class="bi bi-${icons[type]||'info-circle'} me-2"></i><strong>${msg}</strong><button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 4000);
    }

    // ─── Init ───
    let avrGrid, paymentGrid;
    document.addEventListener('DOMContentLoaded', function() {
        avrGrid = createWorkflowGrid('avr-grid', avrData, 'AVR');
        paymentGrid = createWorkflowGrid('payment-grid', paymentData, 'Payment');
        document.querySelector('[data-bs-target="#tab-payment"]').addEventListener('shown.bs.tab', function() {
            if (paymentGrid) paymentGrid.refresh();
        });
    });
</script>
}
