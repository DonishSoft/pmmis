@model PMMIS.Domain.Entities.Tender
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = "Тендер — " + Model.ProcurementPlan.ReferenceNo;
    var statusBadge = Model.Status switch
    {
        TenderStatus.Open => "bg-success",
        TenderStatus.Extended => "bg-warning text-dark",
        TenderStatus.Closed => "bg-secondary",
        TenderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
    var statusText = Model.Status switch
    {
        TenderStatus.Open => "Открыт",
        TenderStatus.Extended => "Продлён",
        TenderStatus.Closed => "Закрыт",
        TenderStatus.Cancelled => "Отменён",
        _ => ""
    };
    var daysLeft = (Model.EndDate - DateTime.Today).Days;
    var isOpen = Model.Status == TenderStatus.Open || Model.Status == TenderStatus.Extended;
    var requestCount = Model.Applicants.Count;
    var participantCount = Model.Applicants.Count(a => a.IsParticipant);
    var winner = Model.Applicants.FirstOrDefault(a => a.IsWinner);
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Тендеры</a></li>
            <li class="breadcrumb-item active">@Model.ProcurementPlan.ReferenceNo</li>
        </ol>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Header -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-megaphone me-2"></i>@Model.ProcurementPlan.ReferenceNo
                        <span class="badge @statusBadge ms-2">@statusText</span>
                    </h4>
                    <p class="text-muted mb-1">@Model.ProcurementPlan.Description</p>
                    <small class="text-muted">
                        <i class="bi bi-diagram-3 me-1"></i>@Model.ProcurementPlan.Project?.Code
                    </small>
                    @if (winner != null)
                    {
                        <div class="mt-2">
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-trophy me-1"></i>Победитель: @winner.CompanyName
                            </span>
                        </div>
                    }
                </div>
                <div class="text-end">
                    <div class="mb-1">
                        <span class="text-muted small">Начало:</span>
                        <strong>@Model.StartDate.ToString("dd.MM.yyyy")</strong>
                    </div>
                    <div class="mb-1">
                        <span class="text-muted small">Окончание:</span>
                        <strong class="@(daysLeft <= 7 && isOpen ? "text-danger" : "")">@Model.EndDate.ToString("dd.MM.yyyy")</strong>
                    </div>
                    @if (isOpen)
                    {
                        <div>
                            @if (daysLeft > 0)
                            {
                                <span class="badge bg-info">@daysLeft дн. осталось</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Срок истёк</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#tabInfo" role="tab">
                <i class="bi bi-info-circle me-1"></i>Информация
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tabRequests" role="tab">
                <i class="bi bi-envelope me-1"></i>Запросы
                <span class="badge bg-secondary ms-1" id="requestsCount">@requestCount</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tabParticipants" role="tab">
                <i class="bi bi-people me-1"></i>Участники
                <span class="badge bg-primary ms-1" id="participantsCount">@participantCount</span>
            </a>
        </li>

    </ul>

    <div class="tab-content border border-top-0 rounded-bottom bg-white">
        <!-- Tab 1: Information -->
        <div class="tab-pane fade show active p-3" id="tabInfo">
            <div class="row">
                <div class="col-md-8">
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mb-3">
                            <h6><i class="bi bi-chat-text me-1"></i>Примечания</h6>
                            <p>@Model.Notes</p>
                        </div>
                    }

                    <!-- Extension History -->
                    <h6 class="mt-3"><i class="bi bi-clock-history me-1"></i>История продлений</h6>
                    @if (Model.Extensions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover" style="font-size:0.85rem">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Предыдущий срок</th>
                                        <th>Новый срок</th>
                                        <th>Причина</th>
                                        <th>Дата продления</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int extNum = 0; }
                                    @foreach (var ext in Model.Extensions)
                                    {
                                        extNum++;
                                        <tr>
                                            <td class="text-muted">@extNum</td>
                                            <td><span class="text-decoration-line-through text-danger">@ext.PreviousEndDate.ToString("dd.MM.yyyy")</span></td>
                                            <td class="text-success fw-semibold">@ext.NewEndDate.ToString("dd.MM.yyyy")</td>
                                            <td>@ext.Reason</td>
                                            <td class="text-muted">@ext.ExtendedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small">Тендер не продлевался</p>
                    }
                </div>

                <div class="col-md-4">
                    <!-- Actions -->
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <h6 class="card-title"><i class="bi bi-gear me-1"></i>Действия</h6>
                            @if (isOpen)
                            {
                                <button class="btn btn-sm btn-warning w-100 mb-2" data-bs-toggle="modal" data-bs-target="#extendModal">
                                    <i class="bi bi-calendar-plus me-1"></i>Продлить срок
                                </button>
                                <form asp-action="CloseTender" method="post" class="mb-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tenderId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-secondary w-100" onclick="return confirm('Закрыть тендер?')">
                                        <i class="bi bi-lock me-1"></i>Закрыть тендер
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Удалить тендер и все данные?')">
                                    <i class="bi bi-trash me-1"></i>Удалить тендер
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Requests (Запросы) -->
        <div class="tab-pane fade p-3" id="tabRequests">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <small class="text-muted">Компании, запросившие тендерную документацию</small>
                </div>
                @if (isOpen)
                {
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addApplicantModal">
                        <i class="bi bi-plus-lg me-1"></i>Добавить компанию
                    </button>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:0.85rem" id="requestsTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Наименование компании</th>
                            <th>Тип</th>
                            <th>Email</th>
                            <th>Телефон</th>
                            <th>Страна</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="requestsBody"></tbody>
                </table>
            </div>
            <p class="text-muted text-center py-3 d-none" id="requestsEmpty">
                <i class="bi bi-inbox d-block fs-3 mb-2" style="opacity:0.3"></i>
                Нет запросов
            </p>
        </div>

        <!-- Tab 3: Participants (Участники) -->
        <div class="tab-pane fade p-3" id="tabParticipants">
            <div class="mb-3">
                <small class="text-muted">Компании, подавшие тендерные документы</small>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:0.85rem" id="participantsTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Наименование компании</th>
                            <th>Тип</th>
                            <th>Страна</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="participantsBody"></tbody>
                </table>
            </div>
            <p class="text-muted text-center py-3 d-none" id="participantsEmpty">
                <i class="bi bi-inbox d-block fs-3 mb-2" style="opacity:0.3"></i>
                Нет участников. Допустите компании из вкладки «Запросы».
            </p>
        </div>


    </div>
</div>

<!-- Extend Deadline Modal -->
<div class="modal fade" id="extendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Продлить срок тендера</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Текущая дата окончания</label>
                    <input type="text" class="form-control" value="@Model.EndDate.ToString("dd.MM.yyyy")" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Новая дата окончания <span class="text-danger">*</span></label>
                    <input type="date" id="newEndDate" class="form-control" min="@Model.EndDate.AddDays(1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Причина продления <span class="text-danger">*</span></label>
                    <textarea id="extendReason" class="form-control" rows="3" placeholder="Укажите причину продления..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-warning" id="btnExtend">
                    <i class="bi bi-calendar-plus me-1"></i>Продлить
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Applicant Modal -->
<div class="modal fade" id="addApplicantModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-building me-2"></i>Добавить компанию</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Наименование компании <span class="text-danger">*</span></label>
                        <input type="text" id="appCompanyName" class="form-control" placeholder="ООО «Строитель»" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Тип компании</label>
                        <select id="appCompanyType" class="form-select">
                            <option value="">— Выберите —</option>
                            <option>ООО</option>
                            <option>ОАО</option>
                            <option>ГУП</option>
                            <option>ИП</option>
                            <option>Joint Venture</option>
                            <option>Consortium</option>
                            <option>LTD</option>
                            <option>LLC</option>
                            <option>Другое</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Электронная почта</label>
                        <input type="email" id="appEmail" class="form-control" placeholder="info@company.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Телефон</label>
                        <input type="text" id="appPhone" class="form-control" placeholder="+992 ..." />
                    </div>
                    <div class="col-md-12">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="appIsForeign" onchange="toggleForeignFields()">
                            <label class="form-check-label" for="appIsForeign">Иностранная компания</label>
                        </div>
                    </div>
                    <div class="col-md-6 d-none" id="countryFields1">
                        <label class="form-label">Страна 1</label>
                        <input type="text" id="appCountry1" class="form-control" placeholder="Например: Китай" />
                    </div>
                    <div class="col-md-6 d-none" id="countryFields2">
                        <label class="form-label">Страна 2 (консорциум)</label>
                        <input type="text" id="appCountry2" class="form-control" placeholder="Необязательно" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-primary" id="btnAddApplicant">
                    <i class="bi bi-plus-lg me-1"></i>Добавить
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Declare Winner Modal -->
<div class="modal fade" id="winnerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-trophy me-2"></i>Объявить победителя</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info small">
                    <i class="bi bi-info-circle me-1"></i>
                    При объявлении победителя автоматически создаются <strong>Подрядчик</strong> и <strong>Контракт</strong>.
                    Статус плана закупок изменится на <strong>«Присуждено»</strong>.
                </div>
                <input type="hidden" id="winnerApplicantId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Компания-победитель</label>
                    <input type="text" id="winnerCompanyName" class="form-control bg-light" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Оценочный документ</label>
                    <input type="file" id="winnerEvalDoc" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx" />
                </div>
                <hr />
                <h6><i class="bi bi-file-earmark-text me-1"></i>Данные контракта</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Номер контракта <span class="text-danger">*</span></label>
                        <input type="text" id="winnerContractNumber" class="form-control bg-light" value="@Model.ProcurementPlan.ReferenceNo" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Дата подписания <span class="text-danger">*</span></label>
                        <input type="date" id="winnerSigningDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Дата окончания <span class="text-danger">*</span></label>
                        <input type="date" id="winnerContractEndDate" class="form-control" />
                    </div>
                </div>
                <hr />
                <h6><i class="bi bi-currency-dollar me-1"></i>Финансы</h6>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Валюта <span class="text-danger">*</span></label>
                        <select id="winnerCurrency" class="form-select">
                            <option value="0">💵 USD — Доллар</option>
                            <option value="1">🇹🇯 TJS — Сомони</option>
                        </select>
                    </div>
                    <div class="col-md-3" id="winnerTjsAmountGroup" style="display:none;">
                        <label class="form-label fw-semibold">Сумма (TJS) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">SM</span>
                            <input type="number" id="winnerAmountTjs" class="form-control" step="0.01" min="0" />
                        </div>
                    </div>
                    <div class="col-md-3" id="winnerRateGroup" style="display:none;">
                        <label class="form-label fw-semibold">Курс USD/TJS</label>
                        <div class="input-group">
                            <span class="input-group-text">📊</span>
                            <input type="number" id="winnerExchangeRate" class="form-control" step="0.0001" readonly />
                        </div>
                        <small class="text-muted" id="winnerRateInfo">На дату подписания</small>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold" id="winnerUsdLabel">Сумма (USD) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" id="winnerContractAmount" class="form-control" step="0.01" min="0" value="@Model.ProcurementPlan.EstimatedAmount" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button class="btn btn-success" id="btnDeclareWinner">
                    <i class="bi bi-trophy me-1"></i>Объявить победителя и создать контракт
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const tenderId = @Model.Id;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    // ======= Load Data =======
    let allApplicants = [];

    async function loadAll() {
        const resp = await fetch(`/Tenders/GetApplicants?tenderId=${tenderId}`);
        allApplicants = await resp.json();
        renderRequests();
        renderParticipants();
    }

    function renderRequests() {
        const data = allApplicants;
        const tbody = document.getElementById('requestsBody');
        const empty = document.getElementById('requestsEmpty');
        document.getElementById('requestsCount').textContent = data.length;

        if (!data.length) {
            tbody.innerHTML = '';
            empty.classList.remove('d-none');
            return;
        }
        empty.classList.add('d-none');

        tbody.innerHTML = data.map((a, i) => {
            let countryInfo = a.isForeign
                ? `<span class="badge bg-warning text-dark">${esc(a.country1 || '')}${a.country2 ? ' / ' + esc(a.country2) : ''}</span>`
                : '<span class="text-muted small">Местная</span>';

            let statusBadge = a.isWinner
                ? '<span class="badge bg-success"><i class="bi bi-trophy"></i> Победитель</span>'
                : a.isParticipant
                    ? '<span class="badge bg-primary">Участник</span>'
                    : '<span class="badge bg-secondary">Запрос</span>';

            let actions = '';
            if (!a.isParticipant) {
                actions += `<button class="btn btn-sm btn-outline-success me-1" onclick="promote(${a.id})" title="Допустить к участию">
                    <i class="bi bi-arrow-right-circle"></i>
                </button>`;
            }
            actions += `<button class="btn btn-sm btn-outline-danger" onclick="removeApplicant(${a.id})" title="Удалить">
                <i class="bi bi-x-lg"></i>
            </button>`;

            return `<tr>
                <td class="text-muted">${i + 1}</td>
                <td><strong>${esc(a.companyName)}</strong></td>
                <td>${esc(a.companyType || '')}</td>
                <td>${a.email ? `<a href="mailto:${esc(a.email)}">${esc(a.email)}</a>` : ''}</td>
                <td>${esc(a.phone || '')}</td>
                <td>${countryInfo}</td>
                <td>${statusBadge}</td>
                <td class="text-end">${actions}</td>
            </tr>`;
        }).join('');
    }

    function renderParticipants() {
        const data = allApplicants.filter(a => a.isParticipant);
        const tbody = document.getElementById('participantsBody');
        const empty = document.getElementById('participantsEmpty');
        document.getElementById('participantsCount').textContent = data.length;

        if (!data.length) {
            tbody.innerHTML = '';
            empty.classList.remove('d-none');
            return;
        }
        empty.classList.add('d-none');

        tbody.innerHTML = data.map((a, i) => {
            let countryInfo = a.isForeign
                ? `<span class="badge bg-warning text-dark">${esc(a.country1 || '')}${a.country2 ? ' / ' + esc(a.country2) : ''}</span>`
                : '<span class="text-muted small">Местная</span>';

            let statusBadge = a.isWinner
                ? '<span class="badge bg-success"><i class="bi bi-trophy me-1"></i>Победитель</span>'
                : '<span class="badge bg-primary">Участник</span>';

            let actions = '';
            if (!a.isWinner) {
                actions += `<button class="btn btn-sm btn-outline-success me-1 btn-declare-winner" data-id="${a.id}" title="Объявить победителем">
                    <i class="bi bi-trophy"></i>
                </button>`;
                actions += `<button class="btn btn-sm btn-outline-secondary" onclick="demote(${a.id})" title="Убрать из участников">
                    <i class="bi bi-arrow-left-circle"></i>
                </button>`;
            } else {
                if (a.evaluationDocPath) {
                    actions += `<a href="${a.evaluationDocPath}" class="btn btn-sm btn-outline-info" target="_blank" title="Оценочный документ">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </a>`;
                }
            }

            return `<tr class="${a.isWinner ? 'table-success' : ''}">
                <td class="text-muted">${i + 1}</td>
                <td><strong>${esc(a.companyName)}</strong></td>
                <td>${esc(a.companyType || '')}</td>
                <td>${countryInfo}</td>
                <td>${statusBadge}</td>
                <td class="text-end">${actions}</td>
            </tr>`;
        }).join('');
    }

    // ======= Actions =======

    async function promote(id) {
        const resp = await fetch(`/Tenders/PromoteToParticipant?applicantId=${id}`, { method: 'POST' });
        const r = await resp.json();
        if (r.success) loadAll();
    }

    async function demote(id) {
        if (!confirm('Убрать из участников?')) return;
        const resp = await fetch(`/Tenders/DemoteFromParticipant?applicantId=${id}`, { method: 'POST' });
        const r = await resp.json();
        if (r.success) loadAll();
    }

    async function removeApplicant(id) {
        if (!confirm('Удалить?')) return;
        const resp = await fetch(`/Tenders/RemoveApplicant?id=${id}`, { method: 'POST' });
        const r = await resp.json();
        if (r.success) loadAll();
    }

    // ======= Winner Modal =======

    // Event delegation for dynamically rendered winner buttons
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.btn-declare-winner');
        if (!btn) return;
        const id = parseInt(btn.dataset.id);
        const applicant = allApplicants.find(a => a.id === id);
        const fullName = applicant ? (applicant.companyType ? applicant.companyType + ' ' + applicant.companyName : applicant.companyName) : '';
        document.getElementById('winnerApplicantId').value = id;
        document.getElementById('winnerCompanyName').value = fullName;
        new bootstrap.Modal(document.getElementById('winnerModal')).show();
    });

    // === Winner Finance Logic ===
    const wCurrency = document.getElementById('winnerCurrency');
    const wTjsGroup = document.getElementById('winnerTjsAmountGroup');
    const wRateGroup = document.getElementById('winnerRateGroup');
    const wAmountTjs = document.getElementById('winnerAmountTjs');
    const wExchRate = document.getElementById('winnerExchangeRate');
    const wAmountUsd = document.getElementById('winnerContractAmount');
    const wSignDate = document.getElementById('winnerSigningDate');
    const wRateInfo = document.getElementById('winnerRateInfo');
    const wUsdLabel = document.getElementById('winnerUsdLabel');

    function wToggleCurrency() {
        const isTjs = wCurrency.value === '1';
        wTjsGroup.style.display = isTjs ? '' : 'none';
        wRateGroup.style.display = isTjs ? '' : 'none';
        if (isTjs) {
            wAmountTjs.setAttribute('required', 'required');
            wAmountUsd.setAttribute('readonly', 'readonly');
            wAmountUsd.removeAttribute('required');
            wUsdLabel.innerHTML = 'Сумма (USD) <small class="text-muted">авто</small>';
            wFetchRate();
        } else {
            wAmountUsd.removeAttribute('readonly');
            wAmountUsd.setAttribute('required', 'required');
            wUsdLabel.innerHTML = 'Сумма (USD) <span class="text-danger">*</span>';
            wExchRate.value = '';
            wAmountTjs.value = '';
        }
    }

    async function wFetchRate() {
        const dateVal = wSignDate?.value;
        if (!dateVal) { wRateInfo.textContent = 'Укажите дату подписания'; return; }
        wRateInfo.innerHTML = '<i class="bi bi-hourglass-split"></i> Загрузка курса...';
        try {
            const resp = await fetch(`/Currency/GetUsdRate?date=${dateVal}`);
            const data = await resp.json();
            if (data.rate) {
                wExchRate.value = data.rate;
                wExchRate.readOnly = true;
                wRateInfo.innerHTML = `<span class="text-success"><i class="bi bi-check-circle me-1"></i>Курс НБТ на ${dateVal}</span>`;
                wCalcUsd();
            } else {
                wExchRate.value = '';
                wExchRate.readOnly = false;
                wRateInfo.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Курс не найден. Введите вручную</span>';
            }
        } catch (e) {
            wExchRate.value = '';
            wExchRate.readOnly = false;
            wRateInfo.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Ошибка загрузки. Введите курс вручную</span>';
        }
    }

    function wCalcUsd() {
        const tjs = parseFloat(wAmountTjs.value) || 0;
        const rate = parseFloat(wExchRate.value) || 0;
        if (rate > 0) wAmountUsd.value = (tjs / rate).toFixed(2);
    }

    wCurrency.addEventListener('change', wToggleCurrency);
    wSignDate.addEventListener('change', () => { if (wCurrency.value === '1') wFetchRate(); });
    wAmountTjs.addEventListener('input', wCalcUsd);
    wExchRate.addEventListener('input', wCalcUsd);

    document.getElementById('btnDeclareWinner')?.addEventListener('click', async () => {
        const applicantId = document.getElementById('winnerApplicantId').value;
        const contractNumber = document.getElementById('winnerContractNumber').value;
        const signingDate = document.getElementById('winnerSigningDate').value;
        const contractEndDate = document.getElementById('winnerContractEndDate').value;
        const contractAmount = document.getElementById('winnerContractAmount').value;
        const currency = wCurrency.value;
        const amountTjs = wAmountTjs.value;
        const exchangeRate = wExchRate.value;
        const evalDoc = document.getElementById('winnerEvalDoc').files[0];

        if (!contractNumber || !signingDate || !contractEndDate || !contractAmount) {
            alert('Заполните все обязательные поля контракта');
            return;
        }
        if (currency === '1' && (!amountTjs || !exchangeRate)) {
            alert('Заполните сумму в TJS');
            return;
        }

        const form = new FormData();
        form.append('applicantId', applicantId);
        form.append('contractNumber', contractNumber);
        form.append('signingDate', signingDate);
        form.append('contractEndDate', contractEndDate);
        form.append('contractAmount', contractAmount);
        form.append('currency', currency);
        if (currency === '1') {
            form.append('amountTjs', amountTjs);
            form.append('exchangeRate', exchangeRate);
        }
        if (evalDoc) form.append('evaluationDoc', evalDoc);

        const resp = await fetch('/Tenders/DeclareWinner', { method: 'POST', body: form });
        const result = await resp.json();
        if (result.success) {
            location.reload();
        } else {
            alert(result.error || 'Ошибка');
        }
    });

    // ======= Add Applicant =======

    document.getElementById('btnAddApplicant')?.addEventListener('click', async () => {
        const data = {
            tenderId,
            companyName: document.getElementById('appCompanyName').value,
            companyType: document.getElementById('appCompanyType').value,
            email: document.getElementById('appEmail').value,
            phone: document.getElementById('appPhone').value,
            isForeign: document.getElementById('appIsForeign').checked,
            country1: document.getElementById('appCountry1').value,
            country2: document.getElementById('appCountry2').value
        };

        if (!data.companyName) { alert('Введите наименование компании'); return; }

        const resp = await fetch('/Tenders/AddApplicant', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await resp.json();
        if (result.success) {
            bootstrap.Modal.getInstance(document.getElementById('addApplicantModal')).hide();
            ['appCompanyName', 'appEmail', 'appPhone', 'appCountry1', 'appCountry2'].forEach(
                id => document.getElementById(id).value = ''
            );
            document.getElementById('appCompanyType').selectedIndex = 0;
            document.getElementById('appIsForeign').checked = false;
            toggleForeignFields();
            loadAll();
        } else {
            alert(result.error || 'Ошибка');
        }
    });

    function toggleForeignFields() {
        const show = document.getElementById('appIsForeign').checked;
        document.getElementById('countryFields1').classList.toggle('d-none', !show);
        document.getElementById('countryFields2').classList.toggle('d-none', !show);
    }

    // ======= Extend Deadline =======
    document.getElementById('btnExtend')?.addEventListener('click', async () => {
        const newDate = document.getElementById('newEndDate').value;
        const reason = document.getElementById('extendReason').value;
        if (!newDate || !reason) { alert('Заполните все поля'); return; }

        const form = new FormData();
        form.append('tenderId', tenderId);
        form.append('newEndDate', newDate);
        form.append('reason', reason);
        form.append('__RequestVerificationToken', token);

        const resp = await fetch('/Tenders/ExtendDeadline', { method: 'POST', body: form });
        const result = await resp.json();
        if (result.success) {
            location.reload();
        } else {
            alert(result.error || 'Ошибка');
        }
    });



    // Init
    loadAll();

    function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
</script>
}
