@{
    ViewData["Title"] = "Шаблоны тендерной документации";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Тендеры</a></li>
            <li class="breadcrumb-item active">Шаблоны</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-text me-2"></i>Шаблоны тендерной документации</h2>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div id="fileManager" style="height: 600px"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    new ej.filemanager.FileManager({
        ajaxSettings: {
            url: '/api/FileManager/FileOperations',
            uploadUrl: '/api/FileManager/Upload',
            downloadUrl: '/api/FileManager/Download'
        },
        path: '/Tenders/',
        view: 'Details'
    }, '#fileManager');
</script>
}
