@model PMMIS.Domain.Entities.District
@{
    ViewData["Title"] = "Редактировать район";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var permissionService = ViewContext.HttpContext.RequestServices.GetRequiredService<PMMIS.Web.Services.IPermissionService>();
    var canDelete = await permissionService.HasPermissionAsync(User, "Geography", "delete");
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">География</a></li>
            <li class="breadcrumb-item active">Редактировать район</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="bi bi-pencil me-2"></i>Редактировать: @Model.NameRu</h5>
                    @if (canDelete)
                    {
                        <form asp-action="DeleteDistrict" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Удалить район и все связанные данные?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Удалить
                            </button>
                        </form>
                    }
                </div>
                <div class="card-body">
                    <form asp-action="EditDistrict" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Код <span class="text-danger">*</span></label>
                                <input asp-for="Code" class="form-control" required />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h6 class="text-muted mb-3"><i class="bi bi-translate me-2"></i>Локализация названия</h6>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">🇷🇺 Русский <span class="text-danger">*</span></label>
                                <input asp-for="NameRu" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">🇹🇯 Тоҷикӣ <span class="text-danger">*</span></label>
                                <input asp-for="NameTj" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">🇺🇸 English <span class="text-danger">*</span></label>
                                <input asp-for="NameEn" class="form-control" required />
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Сохранить
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
