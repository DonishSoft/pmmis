@model PMMIS.Web.ViewModels.WorkProgress.WorkProgressFormViewModel
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = "Новый АВР";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Реестр АВР</a></li>
            <li class="breadcrumb-item active">Новый АВР</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Акт выполненных работ</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Контракт <span class="text-danger">*</span></label>
                                <select asp-for="WorkProgress.ContractId" asp-items="Model.Contracts" class="form-select" required id="contractSelect">
                                    <option value="">— Выберите контракт —</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Дата отчёта <span class="text-danger">*</span></label>
                                <input type="date" asp-for="WorkProgress.ReportDate" class="form-control" required />
                            </div>
                        </div>



                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label class="form-label">Описание выполненных работ</label>
                                <textarea asp-for="WorkProgress.Description" class="form-control" rows="3" 
                                          placeholder="Опишите выполненные работы за период..."></textarea>
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label class="form-label">Проблемы и риски</label>
                                <textarea asp-for="WorkProgress.Issues" class="form-control" rows="2" 
                                          placeholder="Укажите проблемы, задержки, риски (если есть)..."></textarea>
                            </div>
                        </div>

                        <!-- ═══ Финансы и примерная сумма к оплате ═══ -->
                        <div id="financialSection" class="mt-3" style="display:none;">
                            <hr class="my-3">
                            <h6 class="mb-3"><i class="bi bi-currency-dollar me-2"></i>Финансовая информация</h6>
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <div class="border rounded p-3 text-center bg-light">
                                        <small class="text-muted d-block">Общая сумма контракта</small>
                                        <strong class="fs-5 text-primary" id="contractAmountDisplay">—</strong>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded p-3 text-center bg-light">
                                        <small class="text-muted d-block">Уже оплачено</small>
                                        <strong class="fs-5 text-success" id="paidAmountDisplay">—</strong>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar bg-success" id="paidProgressBar" style="width: 0%"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded p-3 text-center" id="remainingCard" style="background: #ecfdf5;">
                                        <small class="text-muted d-block">Остаток для оплаты</small>
                                        <strong class="fs-5 text-dark" id="remainingAmountDisplay">—</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Примерная сумма к оплате</label>
                                    <div class="input-group">
                                        <input type="number" asp-for="WorkProgress.EstimatedPaymentAmount" 
                                               class="form-control" id="estimatedAmount" 
                                               step="0.01" min="0" placeholder="0.00" />
                                        <span class="input-group-text" id="currencyLabel">USD</span>
                                    </div>
                                    <small class="text-muted">Сумма может быть изменена при создании платежа</small>
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div id="amountWarning" class="alert alert-warning py-2 px-3 mb-0 w-100" style="display:none;">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        <span id="warningText"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Indicator Progress Section -->
                @if (Model.ContractIndicators?.Any() == true)
                {
                    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-info">
                        <div class="card-header bg-white">
                            <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Прогресс по индикаторам</h5>
                        </div>
                        <div class="card-body">
                            @for (int i = 0; i < Model.ContractIndicators.Count; i++)
                            {
                                var ci = Model.ContractIndicators[i];
                                <input type="hidden" name="ContractIndicators[@i].ContractIndicatorId" value="@ci.ContractIndicatorId" />
                                <input type="hidden" name="ContractIndicators[@i].IndicatorId" value="@ci.IndicatorId" />
                                <input type="hidden" name="ContractIndicators[@i].IndicatorCode" value="@ci.IndicatorCode" />
                                <input type="hidden" name="ContractIndicators[@i].IndicatorName" value="@ci.IndicatorName" />
                                <input type="hidden" name="ContractIndicators[@i].Unit" value="@ci.Unit" />
                                <input type="hidden" name="ContractIndicators[@i].TargetValue" value="@ci.TargetValue" />
                                <input type="hidden" name="ContractIndicators[@i].PreviousAchieved" value="@ci.PreviousAchieved" />
                                <input type="hidden" name="ContractIndicators[@i].GeoDataSource" value="@((int)ci.GeoDataSource)" />

                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <span class="badge bg-secondary me-2">@ci.IndicatorCode</span>
                                                <strong>@ci.IndicatorName</strong>
                                                @if (ci.HasGeoChecklist)
                                                {
                                                    <span class="badge bg-info ms-2" title="Географическая привязка">
                                                        <i class="bi bi-geo-alt-fill"></i> Чеклист
                                                    </span>
                                                }
                                            </div>
                                            <span class="badge bg-light text-dark">
                                                Цель: @ci.TargetValue @ci.Unit
                                            </span>
                                        </div>

                                        @if (ci.HasGeoChecklist)
                                        {
                                            <!-- Geographic Checklist Mode -->
                                            <div class="geo-checklist" data-index="@i" data-target="@ci.TargetValue" data-previous="@ci.PreviousAchieved">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <small class="text-muted">
                                                        @{
                                                            var itemTypeLabel = ci.GeoDataSource switch
                                                            {
                                                                GeoDataSource.Population or GeoDataSource.FemalePopulation or GeoDataSource.Households => "Сёла",
                                                                GeoDataSource.SchoolCount or GeoDataSource.SchoolStudents => "Школы",
                                                                GeoDataSource.HealthFacilityCount => "Медучреждения",
                                                                _ => "Объекты"
                                                            };
                                                        }
                                                        <i class="bi bi-geo-alt me-1"></i>@itemTypeLabel (@ci.GeoItems.Count)
                                                    </small>
                                                    <div>
                                                        <button type="button" class="btn btn-sm btn-outline-success geo-check-all" data-index="@i">
                                                            <i class="bi bi-check-all"></i> Все
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary geo-uncheck-all" data-index="@i">
                                                            <i class="bi bi-x-lg"></i> Снять
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="list-group list-group-flush">
                                                    @for (int j = 0; j < ci.GeoItems.Count; j++)
                                                    {
                                                        var geo = ci.GeoItems[j];
                                                        <input type="hidden" name="ContractIndicators[@i].GeoItems[@j].ItemId" value="@geo.ItemId" />
                                                        <input type="hidden" name="ContractIndicators[@i].GeoItems[@j].ItemType" value="@((int)geo.ItemType)" />
                                                        <input type="hidden" name="ContractIndicators[@i].GeoItems[@j].Name" value="@geo.Name" />
                                                        <input type="hidden" name="ContractIndicators[@i].GeoItems[@j].Description" value="@geo.Description" />
                                                        <input type="hidden" name="ContractIndicators[@i].GeoItems[@j].NumericValue" value="@geo.NumericValue" />
                                                        
                                                        <label class="list-group-item list-group-item-action d-flex align-items-center py-2">
                                                            <input type="checkbox" 
                                                                   name="ContractIndicators[@i].GeoItems[@j].IsChecked" value="true"
                                                                   class="form-check-input me-3 geo-item-check" 
                                                                   data-index="@i" data-value="@geo.NumericValue" 
                                                                   @(geo.IsChecked ? "checked" : "") />
                                                            @{
                                                                var geoIcon = geo.ItemType switch
                                                                {
                                                                    GeoItemType.Village => "bi-house-fill text-info",
                                                                    GeoItemType.School => "bi-mortarboard-fill text-warning",
                                                                    GeoItemType.HealthFacility => "bi-hospital-fill text-danger",
                                                                    _ => "bi-geo-alt"
                                                                };
                                                            }
                                                            <i class="bi @geoIcon me-2"></i>
                                                            <div class="flex-grow-1">
                                                                <span>@geo.Name</span>
                                                                <small class="text-muted d-block">@geo.Description</small>
                                                            </div>
                                                            <span class="badge bg-light text-dark">@geo.NumericValue</span>
                                                        </label>
                                                    }
                                                </div>
                                                
                                                <!-- Hidden value field that gets auto-calculated -->
                                                <input type="hidden" name="ContractIndicators[@i].Value" class="geo-calculated-value" data-index="@i" value="0" />
                                                
                                                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                                    <small class="text-muted">
                                                        Отмечено: <strong class="geo-checked-count" data-index="@i">0</strong> из @ci.GeoItems.Count
                                                    </small>
                                                    <div class="w-50">
                                                        <div class="progress" style="height: 20px;">
                                                            @{
                                                                var percent = ci.TargetValue > 0 ? Math.Min(100, (ci.PreviousAchieved / ci.TargetValue) * 100) : 0;
                                                                var barClass = percent >= 80 ? "bg-success" : percent >= 50 ? "bg-info" : percent >= 25 ? "bg-warning" : "bg-danger";
                                                            }
                                                            <div class="progress-bar @barClass" id="indicatorBar_@i"
                                                                 style="width: @percent.ToString("F0")%">
                                                                @ci.PreviousAchieved / @ci.TargetValue
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <div class="mt-2">
                                                <label class="form-label small text-muted mb-1">Примечания</label>
                                                <input type="text" name="ContractIndicators[@i].Notes" 
                                                       value="@ci.Notes" class="form-control form-control-sm"
                                                       placeholder="Комментарий..." />
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Classic Input Mode -->
                                            <div class="row g-2 align-items-center">
                                                <div class="col-md-4">
                                                    <label class="form-label small text-muted mb-1">Значение в этом АВР</label>
                                                    @if (ci.Unit != null && ci.Unit.Contains("Да", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <!-- Yes/No Toggle -->
                                                        <input type="hidden" name="ContractIndicators[@i].Value" 
                                                               id="indicatorVal_@i" value="@ci.Value" />
                                                        <div class="form-check form-switch fs-5">
                                                            <input class="form-check-input" type="checkbox" role="switch"
                                                                   id="indicatorSwitch_@i"
                                                                   @(ci.Value >= 1 ? "checked" : "")
                                                                   data-index="@i"
                                                                   data-target="@ci.TargetValue"
                                                                   data-previous="@ci.PreviousAchieved"
                                                                   onchange="toggleYesNo(this)" />
                                                            <label class="form-check-label" id="indicatorSwitchLabel_@i">
                                                                @(ci.Value >= 1 ? "Да ✅" : "Нет ❌")
                                                            </label>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="input-group input-group-sm">
                                                            <input type="number" name="ContractIndicators[@i].Value" 
                                                                   value="@ci.Value" class="form-control indicator-value"
                                                                   min="0" step="0.01" 
                                                                   data-target="@ci.TargetValue" 
                                                                   data-previous="@ci.PreviousAchieved"
                                                                   data-index="@i" />
                                                            <span class="input-group-text">@ci.Unit</span>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label small text-muted mb-1">Примечания</label>
                                                    <input type="text" name="ContractIndicators[@i].Notes" 
                                                           value="@ci.Notes" class="form-control form-control-sm"
                                                           placeholder="Комментарий..." />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label small text-muted mb-1">Прогресс</label>
                                                    <div class="progress" style="height: 20px;">
                                                        @{
                                                            var pct = ci.TargetValue > 0 ? Math.Min(100, (ci.PreviousAchieved / ci.TargetValue) * 100) : 0;
                                                            var cls = pct >= 80 ? "bg-success" : pct >= 50 ? "bg-info" : pct >= 25 ? "bg-warning" : "bg-danger";
                                                        }
                                                        <div class="progress-bar @cls" id="indicatorBar_@i" 
                                                             style="width: @pct.ToString("F0")%">
                                                            @ci.PreviousAchieved / @ci.TargetValue
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.WorkItems?.Any() == true)
                {
                    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-warning">
                        <div class="card-header bg-white p-0">
                            <ul class="nav nav-tabs" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" data-bs-toggle="tab" href="#tabCurrentItems" role="tab">
                                        <i class="bi bi-list-task me-1"></i>Текущие позиции
                                        <span class="badge bg-secondary ms-1">@Model.WorkItems.Count</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" data-bs-toggle="tab" href="#tabImportExcel" role="tab">
                                        <i class="bi bi-file-earmark-excel me-1"></i>Импорт из Excel
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body p-0">
                            <div class="tab-content">
                                <!-- Tab 1: Current Work Items -->
                                <div class="tab-pane fade show active p-3" id="tabCurrentItems">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <small class="text-muted">Введите значения выполненных работ за текущий период</small>
                                        <input type="text" class="form-control form-control-sm" id="workItemSearch"
                                               placeholder="Поиск..." style="width: 200px;" />
                                    </div>
                                    <div style="max-height: 500px; overflow-y: auto;" id="workItemsContainer">
                                        @for (int w = 0; w < Model.WorkItems.Count; w++)
                                        {
                                            var wi = Model.WorkItems[w];
                                            <input type="hidden" name="WorkItems[@w].ContractWorkItemId" value="@wi.ContractWorkItemId" />
                                            <input type="hidden" name="WorkItems[@w].Name" value="@wi.Name" />
                                            <input type="hidden" name="WorkItems[@w].Unit" value="@wi.Unit" />
                                            <input type="hidden" name="WorkItems[@w].TargetQuantity" value="@wi.TargetQuantity" />
                                            <input type="hidden" name="WorkItems[@w].PreviousAchieved" value="@wi.PreviousAchieved" />

                                            <div class="card bg-light mb-2 work-item-card" data-name="@wi.Name.ToLower()" data-index="@w">
                                                <div class="card-body py-2 px-3">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <div>
                                                            <strong class="small">@wi.Name</strong>
                                                            <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">@wi.Unit</span>
                                                        </div>
                                                        <span class="badge bg-warning text-dark" style="font-size: 0.65rem;">
                                                            @wi.PreviousAchieved / @wi.TargetQuantity
                                                        </span>
                                                    </div>
                                                    <div class="row g-2">
                                                        <div class="col-md-4">
                                                            @if (wi.Unit == "Да/Нет")
                                                            {
                                                                <input type="hidden" name="WorkItems[@w].Value" class="wi-value-hidden wi-value-input" data-index="@w" value="@(wi.Value > 0 ? "1" : "0")" />
                                                                <div class="form-check form-switch">
                                                                    <input class="form-check-input" type="checkbox" role="switch"
                                                                           @(wi.Value > 0 ? "checked" : "")
                                                                           onchange="document.querySelector('.wi-value-hidden[data-index=\'@w\']').value = this.checked ? '1' : '0'" />
                                                                    <label class="form-check-label small">Выполнено</label>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <input type="number" name="WorkItems[@w].Value"
                                                                       class="form-control form-control-sm wi-value-input" data-index="@w"
                                                                       value="@wi.Value" min="0" step="0.01"
                                                                       placeholder="0" />
                                                            }
                                                        </div>
                                                        <div class="col-md-8">
                                                            <input type="text" name="WorkItems[@w].Notes"
                                                                   class="form-control form-control-sm"
                                                                   value="@wi.Notes" placeholder="Комментарий..." />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Tab 2: Import from Excel -->
                                <div class="tab-pane fade p-3" id="tabImportExcel">
                                    <div class="alert alert-info mb-3">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Загрузите файл АВР (Excel), и значения «За этот период» будут автоматически заполнены для совпадающих позиций.
                                    </div>

                                    <div class="row g-3 align-items-end mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold">Файл Excel (.xlsx)</label>
                                            <input type="file" class="form-control" id="avrExcelFile" accept=".xlsx,.xls" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold">Режим</label>
                                            <div class="d-flex gap-2">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="avrImportMode" value="ClosedXML" id="avrModeClosedXML" checked />
                                                    <label class="form-check-label small" for="avrModeClosedXML">ClosedXML</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="avrImportMode" value="AI" id="avrModeAI" />
                                                    <label class="form-check-label small" for="avrModeAI">Gemini AI</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <button type="button" class="btn btn-success w-100" id="avrImportBtn">
                                                <i class="bi bi-cloud-upload me-1"></i> Загрузить
                                            </button>
                                        </div>
                                    </div>

                                    <div class="progress d-none" id="avrImportProgress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                                    </div>
                                    <div class="text-center text-muted mt-2 d-none" id="avrImportStatus">
                                        <small id="avrImportStatusText">Обработка...</small>
                                        <small class="ms-2" id="avrImportTimer"></small>
                                    </div>

                                    <!-- Import Results -->
                                    <div class="d-none mt-3" id="avrImportResults">
                                        <div class="row text-center g-3 mb-3">
                                            <div class="col"><div class="border rounded p-2"><small class="text-muted d-block">Найдено</small><strong id="avrFoundCount">0</strong></div></div>
                                            <div class="col"><div class="border rounded p-2"><small class="text-muted d-block">Совпало</small><strong class="text-success" id="avrMatchedCount">0</strong></div></div>
                                            <div class="col"><div class="border rounded p-2"><small class="text-muted d-block">Заполнено</small><strong class="text-primary" id="avrFilledCount">0</strong></div></div>
                                        </div>
                                        <div class="alert alert-success d-none" id="avrImportSuccess"></div>
                                        <div class="alert alert-warning d-none" id="avrImportErrors"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- File Upload Section -->
                <div class="card border-0 shadow-sm mb-4 border-start border-4 border-primary">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-paperclip me-2"></i>Документы и фотоматериалы</h5>
                        <button type="button" class="btn btn-sm btn-success" id="addFileBtn">
                            <i class="bi bi-plus-lg"></i> Добавить файл
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="filesContainer"></div>
                        <div id="noFiles" class="text-center text-muted py-4">
                            <i class="bi bi-cloud-upload fs-1 d-block mb-2"></i>
                            Нажмите «Добавить файл» для загрузки документов и фотографий
                        </div>
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-info-circle me-1"></i>
                            Поддерживаемые форматы: PDF, Word, Excel, изображения (JPG, PNG)
                        </small>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Создать
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <h6><i class="bi bi-info-circle me-2"></i>Подсказка</h6>
                    <p class="small text-muted mb-2">
                        <strong>АВР</strong> — Акт выполненных работ. Документ подтверждает приёмку работ за отчётный период.
                    </p>
                    <p class="small text-muted mb-0">
                        После создания АВР автоматически создаётся задача на проверку документа и 
                        обновляется процент выполнения контракта.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>

    // Yes/No toggle handler for Да/Нет indicators
    function toggleYesNo(checkbox) {
        const idx = checkbox.dataset.index;
        const val = checkbox.checked ? 1 : 0;
        document.getElementById('indicatorVal_' + idx).value = val;
        document.getElementById('indicatorSwitchLabel_' + idx).textContent = checkbox.checked ? 'Да ✅' : 'Нет ❌';
        
        // Update progress bar
        const target = parseFloat(checkbox.dataset.target) || 0;
        const previous = parseFloat(checkbox.dataset.previous) || 0;
        const newTotal = previous + val;
        const percent = target > 0 ? Math.min(100, (newTotal / target) * 100) : 0;
        const bar = document.getElementById('indicatorBar_' + idx);
        if (bar) {
            bar.style.width = percent.toFixed(0) + '%';
            bar.textContent = newTotal + ' / ' + target;
            bar.classList.remove('bg-success', 'bg-info', 'bg-warning', 'bg-danger');
            bar.classList.add(percent >= 80 ? 'bg-success' : percent >= 50 ? 'bg-info' : percent >= 25 ? 'bg-warning' : 'bg-danger');
        }
    }

    // Indicator progress bar live updates
    document.querySelectorAll('.indicator-value').forEach(input => {
        input.addEventListener('input', function() {
            const idx = this.dataset.index;
            const target = parseFloat(this.dataset.target) || 0;
            const previous = parseFloat(this.dataset.previous) || 0;
            const value = parseFloat(this.value) || 0;
            const newTotal = previous + value;
            const percent = target > 0 ? Math.min(100, (newTotal / target) * 100) : 0;

            const bar = document.getElementById('indicatorBar_' + idx);
            if (bar) {
                bar.style.width = percent.toFixed(0) + '%';
                bar.textContent = newTotal + ' / ' + target;
                bar.classList.remove('bg-success', 'bg-info', 'bg-warning', 'bg-danger');
                if (percent >= 80) bar.classList.add('bg-success');
                else if (percent >= 50) bar.classList.add('bg-info');
                else if (percent >= 25) bar.classList.add('bg-warning');
                else bar.classList.add('bg-danger');
            }
        });
    });

    // ========================
    // Geographic Checklist
    // ========================
    function updateGeoChecklist(index) {
        const checkboxes = document.querySelectorAll(`.geo-item-check[data-index="${index}"]`);
        let total = 0;
        let checked = 0;
        checkboxes.forEach(cb => {
            if (cb.checked) {
                total += parseFloat(cb.dataset.value) || 0;
                checked++;
            }
        });
        
        // Update hidden value field
        const valueField = document.querySelector(`.geo-calculated-value[data-index="${index}"]`);
        if (valueField) valueField.value = total;
        
        // Update count display
        const countEl = document.querySelector(`.geo-checked-count[data-index="${index}"]`);
        if (countEl) countEl.textContent = checked;
        
        // Update progress bar
        const container = document.querySelector(`.geo-checklist[data-index="${index}"]`);
        if (container) {
            const target = parseFloat(container.dataset.target) || 0;
            const previous = parseFloat(container.dataset.previous) || 0;
            const newTotal = previous + total;
            const percent = target > 0 ? Math.min(100, (newTotal / target) * 100) : 0;
            
            const bar = document.getElementById('indicatorBar_' + index);
            if (bar) {
                bar.style.width = percent.toFixed(0) + '%';
                bar.textContent = newTotal + ' / ' + target;
                bar.classList.remove('bg-success', 'bg-info', 'bg-warning', 'bg-danger');
                if (percent >= 80) bar.classList.add('bg-success');
                else if (percent >= 50) bar.classList.add('bg-info');
                else if (percent >= 25) bar.classList.add('bg-warning');
                else bar.classList.add('bg-danger');
            }
        }
    }

    // Checkbox change handlers
    document.querySelectorAll('.geo-item-check').forEach(cb => {
        cb.addEventListener('change', function() {
            updateGeoChecklist(this.dataset.index);
        });
    });

    // Check All / Uncheck All buttons
    document.querySelectorAll('.geo-check-all').forEach(btn => {
        btn.addEventListener('click', function() {
            const idx = this.dataset.index;
            document.querySelectorAll(`.geo-item-check[data-index="${idx}"]`).forEach(cb => cb.checked = true);
            updateGeoChecklist(idx);
        });
    });
    document.querySelectorAll('.geo-uncheck-all').forEach(btn => {
        btn.addEventListener('click', function() {
            const idx = this.dataset.index;
            document.querySelectorAll(`.geo-item-check[data-index="${idx}"]`).forEach(cb => cb.checked = false);
            updateGeoChecklist(idx);
        });
    });

    // Initialize geo checklists on page load
    document.querySelectorAll('.geo-checklist').forEach(container => {
        updateGeoChecklist(container.dataset.index);
    });

    // Contract change — reload with new indicators + load financials
    document.getElementById('contractSelect')?.addEventListener('change', function() {
        const contractId = this.value;
        if (contractId) {
            // Disable layout's 'Leave site?' dialog (isDirty from _Layout.cshtml)
            window.isDirty = false;
            if (typeof isDirty !== 'undefined') isDirty = false;
            window.onbeforeunload = null;
            window.location.href = '@Url.Action("Create")' + '?contractId=' + contractId;
        }
    });

    // ========================
    // Financial Data
    // ========================
    let contractFinancials = null;

    async function loadFinancials(contractId) {
        if (!contractId) {
            document.getElementById('financialSection').style.display = 'none';
            return;
        }
        try {
            const resp = await fetch(`@Url.Action("GetContractFinancials")?contractId=${contractId}`);
            const data = await resp.json();
            if (data.success) {
                contractFinancials = data;
                const fmt = (v) => parseFloat(v).toLocaleString('ru-RU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('contractAmountDisplay').textContent = fmt(data.contractAmount) + ' ' + data.currency;
                document.getElementById('paidAmountDisplay').textContent = fmt(data.paidAmount) + ' ' + data.currency;
                document.getElementById('remainingAmountDisplay').textContent = fmt(data.remainingAmount) + ' ' + data.currency;
                document.getElementById('paidProgressBar').style.width = Math.min(100, data.paidPercent) + '%';
                document.getElementById('currencyLabel').textContent = data.currency;
                document.getElementById('financialSection').style.display = 'block';
                validateAmount();
            }
        } catch (e) { console.error('Failed to load financials:', e); }
    }

    function validateAmount() {
        const input = document.getElementById('estimatedAmount');
        const warning = document.getElementById('amountWarning');
        const val = parseFloat(input?.value) || 0;

        if (!contractFinancials || val === 0) {
            warning.style.display = 'none';
            input?.classList.remove('is-invalid');
            return;
        }

        const remaining = contractFinancials.remainingAmount;
        if (val > remaining) {
            const fmt = parseFloat(remaining).toLocaleString('ru-RU', { minimumFractionDigits: 2 });
            document.getElementById('warningText').textContent = 
                `Сумма превышает остаток (${fmt} ${contractFinancials.currency})`;
            warning.style.display = 'block';
            input.classList.add('is-invalid');
        } else {
            warning.style.display = 'none';
            input.classList.remove('is-invalid');
        }
    }

    document.getElementById('estimatedAmount')?.addEventListener('input', validateAmount);

    // Load financials on page load if contract is selected
    const initialContract = document.getElementById('contractSelect')?.value;

    // Work items search
    document.getElementById('workItemSearch')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#workItemsContainer .work-item-card').forEach(card => {
            card.style.display = card.dataset.name?.includes(q) ? '' : 'none';
        });
    });

    // ========================
    // AVR Excel Import
    // ========================
    document.getElementById('avrImportBtn')?.addEventListener('click', async function() {
        const fileInput = document.getElementById('avrExcelFile');
        const file = fileInput?.files?.[0];
        if (!file) { alert('Выберите файл Excel'); return; }

        const contractId = document.getElementById('contractSelect')?.value;
        if (!contractId) { alert('Сначала выберите контракт'); return; }

        const mode = document.querySelector('input[name="avrImportMode"]:checked')?.value || 'ClosedXML';
        const btn = this;
        const progress = document.getElementById('avrImportProgress');
        const statusDiv = document.getElementById('avrImportStatus');
        const statusText = document.getElementById('avrImportStatusText');
        const timerEl = document.getElementById('avrImportTimer');
        const resultsDiv = document.getElementById('avrImportResults');

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Обработка...';
        progress.classList.remove('d-none');
        statusDiv.classList.remove('d-none');
        resultsDiv.classList.add('d-none');
        statusText.textContent = mode === 'AI' ? 'Отправка в Gemini AI...' : 'Анализ файла ClosedXML...';

        let seconds = 0;
        const timer = setInterval(() => {
            seconds++;
            timerEl.textContent = `(${seconds} сек)`;
            if (mode === 'AI' && seconds === 30) statusText.textContent = 'Gemini обрабатывает, подождите...';
        }, 1000);

        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 180000);

        try {
            const formData = new FormData();
            formData.append('file', file);
            formData.append('contractId', contractId);
            formData.append('mode', mode);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            const resp = await fetch('@Url.Action("UploadExcel", "Contracts")', { method: 'POST', body: formData, signal: controller.signal });
            if (!resp.ok) { showAvrError(`Ошибка сервера: ${resp.status}`); return; }

            const text = await resp.text();
            let data;
            try { data = JSON.parse(text); } catch { showAvrError('Некорректный ответ сервера'); return; }

            if (!data.success && data.errors?.length) { showAvrError(data.errors.join('<br>')); return; }

            // Match parsed items to form work items
            const items = data.items || [];
            resultsDiv.classList.remove('d-none');
            document.getElementById('avrFoundCount').textContent = items.length;

            let matched = 0, filled = 0;
            const workCards = document.querySelectorAll('#workItemsContainer .work-item-card');

            function normalize(s) { return (s || '').trim().toLowerCase().replace(/\s+/g, ' ').replace(/ё/g, 'е'); }

            items.forEach(item => {
                const itemName = normalize(item.name);
                const itemNumber = item.itemNumber;

                // Find matching card
                for (const card of workCards) {
                    const cardName = normalize(card.dataset.name);
                    if (cardName === itemName || (itemNumber && cardName.includes(itemNumber + ' '))) {
                        matched++;
                        const idx = card.dataset.index;
                        const valueInput = card.querySelector('.wi-value-input');
                        const thisPeriodQty = item.thisPeriodQuantity || item.thisPeriodQty || 0;

                        if (thisPeriodQty > 0 && valueInput) {
                            valueInput.value = thisPeriodQty;
                            card.style.background = '#d4edda'; // green highlight
                            filled++;
                        }
                        break;
                    }
                }
            });

            document.getElementById('avrMatchedCount').textContent = matched;
            document.getElementById('avrFilledCount').textContent = filled;

            const successDiv = document.getElementById('avrImportSuccess');
            successDiv.classList.remove('d-none');
            successDiv.innerHTML = `<i class="bi bi-check-circle me-1"></i> Готово! Заполнено <strong>${filled}</strong> из <strong>${items.length}</strong> позиций. Перейдите во вкладку «Текущие позиции» для проверки.`;

            if (filled > 0) {
                // Switch to first tab to show filled values
                setTimeout(() => {
                    document.querySelector('a[href="#tabCurrentItems"]')?.click();
                }, 2000);
            }
        } catch(err) {
            if (err.name === 'AbortError') {
                showAvrError('Таймаут (3 мин). Попробуйте ClosedXML.');
            } else {
                showAvrError('Ошибка: ' + err.message);
            }
        } finally {
            clearInterval(timer);
            clearTimeout(timeout);
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cloud-upload me-1"></i> Загрузить';
            progress.classList.add('d-none');
            statusDiv.classList.add('d-none');
        }
    });

    function showAvrError(msg) {
        const resultsDiv = document.getElementById('avrImportResults');
        const errDiv = document.getElementById('avrImportErrors');
        resultsDiv.classList.remove('d-none');
        errDiv.classList.remove('d-none');
        errDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-1"></i> ${msg}`;
    }
    if (initialContract) loadFinancials(initialContract);

    // ========================
    // Dynamic File Upload
    // ========================
    function addFileRow() {
        const container = document.getElementById('filesContainer');
        document.getElementById('noFiles').style.display = 'none';
        
        const row = document.createElement('div');
        row.className = 'row g-2 mb-2 file-row align-items-center p-2 border rounded bg-light';
        row.innerHTML = `
            <div class="col-md-3">
                <select class="form-select form-select-sm file-type-select">
                    <option value="report">📄 Отчёт / Акт</option>
                    <option value="photo">📷 Фотоматериал</option>
                </select>
            </div>
            <div class="col-md-7">
                <input type="file" class="form-control form-control-sm file-input"
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" />
            </div>
            <div class="col-md-2 text-center">
                <button type="button" class="btn btn-outline-danger btn-sm remove-file-btn">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
        
        row.querySelector('.remove-file-btn').addEventListener('click', () => {
            row.remove();
            if (container.children.length === 0) {
                document.getElementById('noFiles').style.display = 'block';
            }
        });
    }
    
    document.getElementById('addFileBtn').addEventListener('click', addFileRow);
    
    // Before submit: assign correct names to file inputs
    document.querySelector('form').addEventListener('submit', function() {
        document.querySelectorAll('.file-row').forEach(row => {
            const type = row.querySelector('.file-type-select')?.value;
            const input = row.querySelector('.file-input');
            if (input && input.files.length > 0) {
                input.name = type === 'photo' ? 'PhotoFiles' : 'ReportFiles';
            }
        });
    });
</script>
}
