@model PMMIS.Domain.Entities.WorkProgress
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = "АВР #" + Model.Id;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var createdDate = Model.CreatedAt.ToString("dd.MM.yyyy HH:mm");
    var updatedDate = Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm") : "";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Реестр АВР</a></li>
            <li class="breadcrumb-item active">АВР #@Model.Id</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-check me-2"></i>
                        Акт выполненных работ
                    </h5>
                    <div>
                        <span class="badge bg-primary fs-6">@Model.CompletedPercent%</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Контракт</label>
                            <p class="mb-0">
                                <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.ContractId" class="text-decoration-none">
                                    <strong>@Model.Contract.ContractNumber</strong>
                                </a>
                            </p>
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small">Дата отчёта</label>
                            <p class="mb-0"><strong>@Model.ReportDate.ToString("dd.MM.yyyy")</strong></p>
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small">Прогресс</label>
                            @{
                                var progressClass = Model.CompletedPercent >= 80 ? "bg-success" : 
                                                   Model.CompletedPercent >= 50 ? "bg-info" : 
                                                   Model.CompletedPercent >= 25 ? "bg-warning" : "bg-danger";
                            }
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar @progressClass" style="width: @Model.CompletedPercent%">
                                    @Model.CompletedPercent%
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="text-muted small">Подрядчик</label>
                            <p class="mb-0">@Model.Contract.Contractor.Name</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="text-muted small">Проект</label>
                            <p class="mb-0">@Model.Contract.Project.NameRu (@Model.Contract.Project.Code)</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <label class="text-muted small">Описание выполненных работ</label>
                                <p class="mb-0">@Model.Description</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Issues))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <label class="text-muted small">Проблемы и риски</label>
                                <div class="alert alert-warning mb-0">
                                    <i class="bi bi-exclamation-triangle me-2"></i>@Model.Issues
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @{
                var stepInfo = ViewBag.WorkflowStep as PMMIS.Web.Services.WorkflowStepInfo;
                var canApprove = (bool)(ViewBag.CanApprove ?? false);
            }

            @if (stepInfo != null)
            {
                <!-- Workflow Status Bar -->
                <div class="card border-0 shadow-sm mb-4 border-start border-4 @(stepInfo.IsCompleted ? "border-success" : "border-warning")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">
                                <i class="bi bi-diagram-3 me-2"></i>Цепочка утверждения
                            </h6>
                            @if (stepInfo.IsCompleted)
                            {
                                <span class="badge bg-success fs-6">✅ Утверждён</span>
                            }
                            else if (Model.ApprovalStatus == AvrApprovalStatus.Rejected)
                            {
                                <span class="badge bg-danger fs-6">❌ Отклонён</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark fs-6">
                                    Шаг @stepInfo.StepOrder из @stepInfo.TotalSteps — @stepInfo.StepName
                                </span>
                            }
                        </div>

                        <!-- Step progress pipeline -->
                        <div class="d-flex align-items-center gap-1 mt-3">
                            @for (int s = 1; s <= stepInfo.TotalSteps; s++)
                            {
                                var isActive = s == stepInfo.StepOrder && !stepInfo.IsCompleted;
                                var isPast = s < stepInfo.StepOrder || stepInfo.IsCompleted;
                                var bgClass = isPast ? "bg-success text-white" : isActive ? "bg-warning text-dark" : "bg-light text-muted";
                                <div class="flex-fill text-center rounded py-1 @bgClass" style="font-size: 0.85rem;">
                                    @s
                                </div>
                                if (s < stepInfo.TotalSteps)
                                {
                                    <i class="bi bi-arrow-right text-muted"></i>
                                }
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.RejectionReason))
                        {
                            <div class="alert alert-danger mt-3 mb-0 py-2">
                                <i class="bi bi-x-circle me-1"></i>
                                <strong>Причина отклонения:</strong> @Model.RejectionReason
                            </div>
                        }

                        @if (canApprove && !stepInfo.IsCompleted)
                        {
                            <div class="d-flex gap-2 mt-3">
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success" 
                                            onclick="return confirm('Утвердить АВР на этом шаге?');">
                                        <i class="bi bi-check-lg me-1"></i> Утвердить
                                    </button>
                                </form>
                                @if (stepInfo.CanReject)
                                {
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                        <i class="bi bi-x-lg me-1"></i> Отклонить
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil me-1"></i> Редактировать
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Назад к реестру
                </a>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-file-text me-2"></i>Контракт</h6>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>@Model.Contract.ContractNumber</strong></p>
                    <p class="text-muted small mb-2">@Model.Contract.ScopeOfWork</p>
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Сумма:</span>
                        <strong>$@Model.Contract.ContractAmount.ToString("N0")</strong>
                    </div>
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Срок до:</span>
                        <strong>@Model.Contract.ContractEndDate.ToString("dd.MM.yyyy")</strong>
                    </div>
                </div>
            </div>

            @if (Model.Documents.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-paperclip me-2"></i>Прикреплённые документы</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var doc in Model.Documents)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        <i class="bi bi-file-earmark me-2"></i>
                                        @(doc.Description ?? doc.OriginalFileName)
                                    </span>
                                    <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-download"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center text-muted">
                        <i class="bi bi-folder2-open fs-1 d-block mb-2"></i>
                        Нет прикреплённых документов
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm mt-4 bg-light">
                <div class="card-body small text-muted">
                    <div><i class="bi bi-clock me-1"></i> Создано: @createdDate</div>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div><i class="bi bi-pencil me-1"></i> Изменено: @updatedDate</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @{
        var historyList = ViewBag.WorkflowHistory as List<PMMIS.Domain.Entities.WorkflowHistory>;
    }

    @if (historyList != null && historyList.Any())
    {
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>История утверждения</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px"></th>
                                <th>Шаг</th>
                                <th>Действие</th>
                                <th>Пользователь</th>
                                <th>Роль</th>
                                <th>Дата</th>
                                <th>Дедлайн</th>
                                <th>Примечание</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in historyList)
                            {
                                var actionIcon = h.Action switch
                                {
                                    PMMIS.Domain.Entities.WorkflowAction.Created => "bi-plus-circle text-primary",
                                    PMMIS.Domain.Entities.WorkflowAction.Submitted => "bi-send text-info",
                                    PMMIS.Domain.Entities.WorkflowAction.Approved => "bi-check-circle text-success",
                                    PMMIS.Domain.Entities.WorkflowAction.FinalApproved => "bi-trophy text-success",
                                    PMMIS.Domain.Entities.WorkflowAction.Rejected => "bi-x-circle text-danger",
                                    PMMIS.Domain.Entities.WorkflowAction.Edited => "bi-pencil text-warning",
                                    PMMIS.Domain.Entities.WorkflowAction.Resubmitted => "bi-arrow-repeat text-info",
                                    _ => "bi-circle text-muted"
                                };
                                var actionLabel = h.Action switch
                                {
                                    PMMIS.Domain.Entities.WorkflowAction.Created => "Создан",
                                    PMMIS.Domain.Entities.WorkflowAction.Submitted => "Отправлен",
                                    PMMIS.Domain.Entities.WorkflowAction.Approved => "Утверждён",
                                    PMMIS.Domain.Entities.WorkflowAction.FinalApproved => "Финально утверждён",
                                    PMMIS.Domain.Entities.WorkflowAction.Rejected => "Отклонён",
                                    PMMIS.Domain.Entities.WorkflowAction.Edited => "Отредактирован",
                                    PMMIS.Domain.Entities.WorkflowAction.Resubmitted => "Повторно отправлен",
                                    _ => "—"
                                };
                                var rowClass = h.IsOverdue ? "table-danger" : 
                                              h.Action == PMMIS.Domain.Entities.WorkflowAction.Rejected ? "table-warning" : "";
                                <tr class="@rowClass">
                                    <td class="text-center"><i class="bi @actionIcon fs-5"></i></td>
                                    <td>
                                        <span class="badge bg-secondary">@h.StepOrder</span>
                                        <span class="ms-1 small">@h.StepName</span>
                                    </td>
                                    <td><strong>@actionLabel</strong></td>
                                    <td>@h.UserName</td>
                                    <td><span class="badge bg-outline-secondary border">@h.RoleName</span></td>
                                    <td>
                                        <span class="@(h.IsOverdue ? "text-danger fw-bold" : "")">
                                            @h.ActionDate.AddHours(5).ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                        @if (h.IsOverdue)
                                        {
                                            <br/><small class="text-danger"><i class="bi bi-exclamation-triangle"></i> Просрочено</small>
                                        }
                                    </td>
                                    <td>
                                        @if (h.DueDate.HasValue)
                                        {
                                            @h.DueDate.Value.AddHours(5).ToString("dd.MM.yyyy HH:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td><small class="text-muted">@h.Notes</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-x-circle me-2 text-danger"></i>Отклонить АВР</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Причина отклонения <span class="text-danger">*</span></label>
                    <textarea name="reason" class="form-control" rows="3" required
                              placeholder="Укажите причину отклонения..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-lg me-1"></i> Отклонить
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
