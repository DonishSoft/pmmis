@model PMMIS.Domain.Entities.ProcurementPlan
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = "Редактирование закупки";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">План закупок</a></li>
            <li class="breadcrumb-item active">@Model.ReferenceNo</li>
        </ol>
    </nav>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-10">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Референс номер <span class="text-danger">*</span></label>
                                <input type="text" asp-for="ReferenceNo" class="form-control" required />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label">Описание <span class="text-danger">*</span></label>
                                <input type="text" asp-for="Description" class="form-control" required />
                            </div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label">🇹🇯 Тавсиф (тоҷикӣ) <span class="text-muted small">— необязательно</span></label>
                                <input type="text" asp-for="DescriptionTj" class="form-control" placeholder="Тавсифи харид бо забони тоҷикӣ" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">🇬🇧 Description (English) <span class="text-muted small">— optional</span></label>
                                <input type="text" asp-for="DescriptionEn" class="form-control" placeholder="Procurement description in English" />
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-4">
                                <label class="form-label">Проект</label>
                                <select asp-for="ProjectId" asp-items="ViewBag.Projects" class="form-select" id="projectSelect">
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Компонент</label>
                                <select asp-for="ComponentId" asp-items="ViewBag.Components" class="form-select" id="componentSelect">
                                    <option value="">— Необязательно —</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Подкомпонент</label>
                                <select asp-for="SubComponentId" asp-items="ViewBag.SubComponents" class="form-select" id="subComponentSelect">
                                    <option value="">— Необязательно —</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-3">
                                <label class="form-label">Метод закупки</label>
                                <select asp-for="Method" class="form-select">
                                    <option value="@((int)ProcurementMethod.NCB)">NCB</option>
                                    <option value="@((int)ProcurementMethod.ICB)">ICB</option>
                                    <option value="@((int)ProcurementMethod.Shopping)">Shopping</option>
                                    <option value="@((int)ProcurementMethod.DirectContracting)">Direct Contracting</option>
                                    <option value="@((int)ProcurementMethod.CQS)">CQS</option>
                                    <option value="@((int)ProcurementMethod.QCBS)">QCBS</option>
                                    <option value="@((int)ProcurementMethod.LCS)">LCS</option>
                                    <option value="@((int)ProcurementMethod.FBS)">FBS</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Тип закупки</label>
                                <select asp-for="Type" class="form-select">
                                    <option value="@((int)ProcurementType.Goods)">Товары</option>
                                    <option value="@((int)ProcurementType.Works)">Работы</option>
                                    <option value="@((int)ProcurementType.ConsultingServices)">Консультационные услуги</option>
                                    <option value="@((int)ProcurementType.NonConsultingServices)">Некон. услуги</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Оценочная сумма (USD)</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" asp-for="EstimatedAmount" class="form-control" step="0.01" min="0" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Статус <span class="badge bg-info">авто</span></label>
                                <input type="hidden" asp-for="Status" />
                                @{
                                    var statusInfo = Model.Status switch
                                    {
                                        ProcurementStatus.Planned => ("bg-secondary", "🔵 Запланировано"),
                                        ProcurementStatus.InProgress => ("bg-primary", "⏳ В процессе"),
                                        ProcurementStatus.Evaluation => ("bg-warning text-dark", "📋 Оценка"),
                                        ProcurementStatus.Awarded => ("bg-success", "🏆 Присуждено"),
                                        ProcurementStatus.Completed => ("bg-dark", "✅ Завершено"),
                                        ProcurementStatus.Cancelled => ("bg-danger", "❌ Отменено"),
                                        _ => ("bg-secondary", "—")
                                    };
                                }
                                <div class="form-control-plaintext">
                                    <span class="badge @statusInfo.Item1 fs-6">@statusInfo.Item2</span>
                                </div>
                                <small class="text-muted">Определяется автоматически</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Сроки</h5>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Плановые даты</h6>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Дата объявления</label>
                                <input type="date" asp-for="AdvertisementDate" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Дата тендера</label>
                                <input type="date" asp-for="PlannedBidOpeningDate" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Дата подписания</label>
                                <input type="date" asp-for="PlannedContractSigningDate" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Завершение</label>
                                <input type="date" asp-for="PlannedCompletionDate" class="form-control" />
                            </div>
                        </div>

                        <h6 class="text-muted mb-3 mt-4">Фактические даты</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Дата тендера</label>
                                <input type="date" asp-for="ActualBidOpeningDate" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Дата подписания</label>
                                <input type="date" asp-for="ActualContractSigningDate" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Завершение</label>
                                <input type="date" asp-for="ActualCompletionDate" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-link-45deg me-2"></i>Связь с контрактом</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Контракт (после подписания)</label>
                                <select asp-for="ContractId" asp-items="ViewBag.Contracts" class="form-select">
                                    <option value="">— Не связан —</option>
                                </select>
                                <small class="text-muted">Связать эту позицию с подписанным контрактом</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-chat-left-text me-2"></i>Комментарии</h5>
                    </div>
                    <div class="card-body">
                        <textarea asp-for="Comments" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Сохранить
                    </button>
                    <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('projectSelect').addEventListener('change', async function() {
        const projectId = this.value;
        const componentSelect = document.getElementById('componentSelect');
        const subComponentSelect = document.getElementById('subComponentSelect');
        
        componentSelect.innerHTML = '<option value="">— Необязательно —</option>';
        subComponentSelect.innerHTML = '<option value="">— Необязательно —</option>';
        
        if (projectId) {
            const response = await fetch(`/Procurement/GetComponentsByProject?projectId=${projectId}`);
            const components = await response.json();
            components.forEach(c => {
                componentSelect.innerHTML += `<option value="${c.id}">${c.name}</option>`;
            });
        }
    });

    document.getElementById('componentSelect').addEventListener('change', async function() {
        const componentId = this.value;
        const subComponentSelect = document.getElementById('subComponentSelect');
        
        subComponentSelect.innerHTML = '<option value="">— Необязательно —</option>';
        
        if (componentId) {
            const response = await fetch(`/Procurement/GetSubComponentsByComponent?componentId=${componentId}`);
            const subComponents = await response.json();
            subComponents.forEach(sc => {
                subComponentSelect.innerHTML += `<option value="${sc.id}">${sc.name}</option>`;
            });
        }
    });
</script>
}
