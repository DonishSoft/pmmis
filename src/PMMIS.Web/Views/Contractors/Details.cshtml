@model PMMIS.Domain.Entities.Contractor
@using PMMIS.Domain.Entities
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var permissionService = ViewContext.HttpContext.RequestServices.GetRequiredService<PMMIS.Web.Services.IPermissionService>();
    var canEdit = await permissionService.HasPermissionAsync(User, "Contractors", "edit");
    var totalContractAmount = Model.Contracts.Sum(c => c.FinalAmount);
    var totalPaid = Model.Contracts.Sum(c => c.PaidAmount);
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Подрядчики</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-building me-2"></i>@Model.Name</h2>
            @if (!string.IsNullOrEmpty(Model.Country))
            {
                <p class="text-muted mb-0"><i class="bi bi-geo-alt me-1"></i>@Model.Country</p>
            }
        </div>
        <div class="d-flex gap-2">
            @if (canEdit)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil me-1"></i> Редактировать
                </a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Назад
            </a>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="text-muted small">Контрактов</div>
                    <div class="fs-3 fw-bold text-primary">@Model.Contracts.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="text-muted small">Общая сумма</div>
                    <div class="fs-3 fw-bold text-info">$@totalContractAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="text-muted small">Оплачено</div>
                    <div class="fs-3 fw-bold text-success">$@totalPaid.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="text-muted small">К оплате</div>
                    <div class="fs-3 fw-bold text-warning">$@((totalContractAmount - totalPaid).ToString("N0"))</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <!-- Contracts List -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Контракты</h5>
                    <span class="badge bg-secondary">@Model.Contracts.Count контрактов</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Contracts.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Номер</th>
                                    <th>Объём работ</th>
                                    <th>Тип</th>
                                    <th class="text-end">Сумма ($)</th>
                                    <th>Срок</th>
                                    <th class="text-center">Выполнено</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contract in Model.Contracts.OrderBy(c => c.SigningDate))
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.Id">
                                                @contract.ContractNumber
                                            </a>
                                        </td>
                                        <td>
                                            <span title="@contract.ScopeOfWork">
                                                @(contract.ScopeOfWork.Length > 60 ? contract.ScopeOfWork[..60] + "..." : contract.ScopeOfWork)
                                            </span>
                                        </td>
                                        <td>
                                            @switch (contract.Type)
                                            {
                                                case ContractType.Works:
                                                    <span class="badge bg-warning text-dark">Работы</span>
                                                    break;
                                                case ContractType.Consulting:
                                                    <span class="badge bg-info">Консалт</span>
                                                    break;
                                                case ContractType.Goods:
                                                    <span class="badge bg-primary">Товары</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-end fw-semibold">$@contract.FinalAmount.ToString("N0")</td>
                                        <td>
                                            <small>@contract.SigningDate.ToString("dd.MM.yyyy") — @contract.ContractEndDate.ToString("dd.MM.yyyy")</small>
                                        </td>
                                        <td class="text-center">
                                            @if (contract.WorkCompletedPercent >= 100)
                                            {
                                                <span class="badge bg-success">100%</span>
                                            }
                                            else
                                            {
                                                <div class="progress" style="height: 20px; min-width: 60px;">
                                                    <div class="progress-bar bg-info" style="width: @contract.WorkCompletedPercent%">
                                                        @contract.WorkCompletedPercent%
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Нет контрактов
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <!-- Contact Info -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i>Контактные данные</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ContactPerson))
                    {
                        <p class="mb-2"><i class="bi bi-person me-2"></i>@Model.ContactPerson</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <p class="mb-2"><i class="bi bi-envelope me-2"></i><a href="mailto:@Model.Email">@Model.Email</a></p>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <p class="mb-2"><i class="bi bi-telephone me-2"></i>@Model.Phone</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <p class="mb-0"><i class="bi bi-geo me-2"></i>@Model.Address</p>
                    }
                    @if (string.IsNullOrEmpty(Model.ContactPerson) && string.IsNullOrEmpty(Model.Email) && string.IsNullOrEmpty(Model.Phone) && string.IsNullOrEmpty(Model.Address))
                    {
                        <p class="text-muted mb-0 text-center">Контактные данные не указаны</p>
                    }
                </div>
            </div>

            <!-- Documents -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-folder me-2"></i>Документы</h5>
                    @if (canEdit)
                    {
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadDocModal">
                            <i class="bi bi-upload me-1"></i> Загрузить
                        </button>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.Documents.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px">№</th>
                                    <th>Тип</th>
                                    <th>Название</th>
                                    <th class="text-end">Размер</th>
                                    @if (canEdit)
                                    {
                                        <th style="width:50px"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in Model.Documents.OrderBy(d => d.SortOrder).ThenBy(d => d.CreatedAt))
                                {
                                    <tr>
                                        <td class="text-muted">@doc.SortOrder</td>
                                        <td>
                                            @{
                                                var (typeName, typeClass) = doc.Type switch
                                                {
                                                    DocumentType.CompanyRegistration => ("Регистрация", "bg-success"),
                                                    DocumentType.CompanyLicense       => ("Лицензия", "bg-info"),
                                                    DocumentType.TaxCertificate       => ("Налоговый серт.", "bg-warning text-dark"),
                                                    DocumentType.BankDetails          => ("Банк. реквизиты", "bg-primary"),
                                                    DocumentType.Insurance            => ("Страховка", "bg-danger"),
                                                    DocumentType.Contract             => ("Контракт", "bg-secondary"),
                                                    DocumentType.SignedContract        => ("Подп. контракт", "bg-dark"),
                                                    DocumentType.TenderDocument       => ("Тендер", "bg-info"),
                                                    DocumentType.Report               => ("Отчёт", "bg-primary"),
                                                    _                                 => ("Прочее", "bg-secondary")
                                                };
                                            }
                                            <span class="badge @typeClass" style="font-size: 0.7rem;">@typeName</span>
                                        </td>
                                        <td>
                                            <a href="@doc.FilePath" target="_blank" class="text-decoration-none">
                                                <i class="bi bi-file-earmark me-1"></i>@(doc.Description ?? doc.OriginalFileName)
                                            </a>
                                        </td>
                                        <td class="text-end text-muted small">
                                            @if (doc.FileSize > 1048576)
                                            {
                                                @($"{doc.FileSize / 1048576.0:F1} МБ")
                                            }
                                            else
                                            {
                                                @($"{doc.FileSize / 1024.0:F0} КБ")
                                            }
                                        </td>
                                        @if (canEdit)
                                        {
                                            <td>
                                                <form asp-action="DeleteDocument" method="post" onsubmit="return confirm('Удалить документ?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@doc.Id" />
                                                    <input type="hidden" name="contractorId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Удалить">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-folder2-open fs-1 d-block mb-2"></i>
                            Нет документов
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- История изменений -->
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="bi bi-clock-history me-2"></i>История изменений
            </h5>
            <span class="badge bg-secondary" id="historyCount">0</span>
        </div>
        <div class="card-body p-0">
            <div id="historyBody"></div>
            <div class="text-center py-2 d-none" id="historyShowAll">
                <button class="btn btn-sm btn-outline-secondary" onclick="showAllHistory()">
                    <i class="bi bi-chevron-down me-1" id="historyToggleIcon"></i><span id="historyToggleText">Показать все изменения</span>
                </button>
            </div>
            <div class="text-center text-muted py-4 d-none" id="historyEmpty">
                <i class="bi bi-clock fs-3 d-block mb-1"></i>
                Нет записей в журнале изменений
            </div>
        </div>
    </div>
</div>

<!-- Upload Document Modal -->
@if (canEdit)
{
    <div class="modal fade" id="uploadDocModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="UploadDocuments" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="contractorId" value="@Model.Id" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Загрузка документа</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Тип документа <span class="text-danger">*</span></label>
                            <select name="documentType" class="form-select" required>
                                <option value="">— Выберите тип —</option>
                                <option value="@((int)DocumentType.CompanyRegistration)">📄 Свидетельство регистрации</option>
                                <option value="@((int)DocumentType.CompanyLicense)">📜 Лицензия</option>
                                <option value="@((int)DocumentType.TaxCertificate)">🏛️ Налоговый сертификат</option>
                                <option value="@((int)DocumentType.BankDetails)">🏦 Банковские реквизиты</option>
                                <option value="@((int)DocumentType.Insurance)">🛡️ Страховка</option>
                                <option value="@((int)DocumentType.Contract)">📑 Контракт</option>
                                <option value="@((int)DocumentType.SignedContract)">✍️ Подписанный контракт</option>
                                <option value="@((int)DocumentType.TenderDocument)">📋 Тендерная документация</option>
                                <option value="@((int)DocumentType.Report)">📊 Отчёт</option>
                                <option value="@((int)DocumentType.Other)">📎 Прочее</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Файл <span class="text-danger">*</span></label>
                            <input type="file" name="files" class="form-control" id="docFileInput" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Название документа</label>
                            <input type="text" name="description" class="form-control" id="docNameInput" placeholder="По умолчанию — имя файла">
                            <div class="form-text">Оставьте пустым, чтобы использовать имя загружаемого файла</div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-semibold">Порядок сортировки</label>
                            <input type="number" name="sortOrder" class="form-control" value="@(Model.Documents.Any() ? Model.Documents.Max(d => d.SortOrder) + 1 : 1)" min="0">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1"></i> Загрузить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    // Auto-fill document name from file name
    document.getElementById('docFileInput')?.addEventListener('change', function() {
        var nameInput = document.getElementById('docNameInput');
        if (nameInput && !nameInput.value && this.files.length > 0) {
            var fileName = this.files[0].name;
            var lastDot = fileName.lastIndexOf('.');
            if (lastDot > 0) fileName = fileName.substring(0, lastDot);
            nameInput.value = fileName;
        }
    });

    // ===== Change History Loading =====
    (async function() {
        const resp = await fetch('/Contractors/GetHistory?id=@Model.Id');
        if (!resp.ok) return;
        const logs = await resp.json();
        const body = document.getElementById('historyBody');
        const empty = document.getElementById('historyEmpty');
        const count = document.getElementById('historyCount');

        if (logs.length === 0) { empty.classList.remove('d-none'); count.textContent = '0'; return; }
        count.textContent = logs.length;

        function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        function renderItem(log) {
            const dt = new Date(log.timestamp);
            const dateStr = dt.toLocaleDateString('ru-RU', { day:'2-digit', month:'2-digit', year:'numeric' }) 
                          + ' ' + dt.toLocaleTimeString('ru-RU', { hour:'2-digit', minute:'2-digit' });
            let actionBadge = log.action === 'Создание' ? '<span class="badge bg-success">Создание</span>'
                : log.action === 'Удаление' ? '<span class="badge bg-danger">Удаление</span>'
                : '<span class="badge bg-primary">Изменение</span>';
            let changesHtml = '';
            if (log.changes) {
                try {
                    const changes = JSON.parse(log.changes);
                    changesHtml = '<div class="mt-2">';
                    changes.forEach(c => { changesHtml += '<div class="small mb-1"><strong>' + esc(c.Field) + ':</strong> <span class="text-danger text-decoration-line-through">' + esc(c.OldValue) + '</span> → <span class="text-success fw-semibold">' + esc(c.NewValue) + '</span></div>'; });
                    changesHtml += '</div>';
                } catch(e) {}
            }
            return '<div class="list-group-item px-4 py-3"><div class="d-flex justify-content-between align-items-start"><div>' + actionBadge + ' <strong>' + esc(log.userFullName) + '</strong>' + (log.userPosition ? ' <span class="text-muted small">(' + esc(log.userPosition) + ')</span>' : '') + '</div><small class="text-muted"><i class="bi bi-clock me-1"></i>' + dateStr + '</small></div>' + changesHtml + '</div>';
        }

        // Show only latest
        body.innerHTML = '<div class="list-group list-group-flush">' + renderItem(logs[0]) + '</div>';
        window._allLogs = logs;
        window._renderItem = renderItem;
        window._esc = esc;
        if (logs.length > 1) document.getElementById('historyShowAll').classList.remove('d-none');
    })();

    function showAllHistory() {
        const body = document.getElementById('historyBody');
        const icon = document.getElementById('historyToggleIcon');
        const text = document.getElementById('historyToggleText');
        const isExpanded = body.dataset.expanded === 'true';
        
        if (!isExpanded) {
            let html = '<div class="list-group list-group-flush">';
            window._allLogs.forEach(log => { html += window._renderItem(log); });
            html += '</div>';
            body.innerHTML = html;
            body.dataset.expanded = 'true';
            icon.className = 'bi bi-chevron-up me-1';
            text.textContent = 'Скрыть изменения';
        } else {
            body.innerHTML = '<div class="list-group list-group-flush">' + window._renderItem(window._allLogs[0]) + '</div>';
            body.dataset.expanded = 'false';
            icon.className = 'bi bi-chevron-down me-1';
            text.textContent = 'Показать все изменения';
        }
    }
</script>
}

