                            <i class="bi bi-gear me-2"></i>
                            <span class="sidebar-text">Настройки</span>
                        </a>
                    }
                    @if (CanView(MenuKeys.Workflow))
                    {
                        <a class="nav-link text-white @(currentController == "Workflow" ? "menu-active" : "")" asp-controller="Workflow" asp-action="Index">
                            <i class="bi bi-arrow-repeat me-2"></i>
                            <span class="sidebar-text">Цепочка утверждений</span>
                        </a>
                    }
                }
            </nav>
        </div>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="flex-grow-1">
            <!-- Top Navbar -->
            <nav class="navbar navbar-light bg-white border-bottom px-4">
